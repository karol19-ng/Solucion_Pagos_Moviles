@page
@model Pegasos.Web.Administrador.Pages.ClientesCore.IndexModel
@{
    ViewData["Title"] = "Administración de Clientes - Core Bancario";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Clientes del Core Bancario</h1>
        <a asp-page="./Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Nuevo Cliente
        </a>
    </div>

    <!-- Buscador -->
    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" class="form-control" id="searchInput"
                       placeholder="Buscar por nombre o identificación...">
                <button class="btn btn-outline-secondary" type="button" id="searchButton">
                    <i class="fas fa-search"></i> Buscar
                </button>
                <button class="btn btn-outline-secondary" type="button" id="clearButton">
                    <i class="fas fa-times"></i> Limpiar
                </button>
            </div>
        </div>
    </div>

    <!-- Tabla de clientes -->
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tipo Identificación</th>
                    <th>Identificación</th>
                    <th>Nombre Completo</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="clientesTableBody">
                @if (Model.Clientes != null && Model.Clientes.Any())
                {
                    @foreach (var cliente in Model.Clientes)
                    {
                        <tr>
                            <td>@cliente.Id</td>
                            <td>@cliente.TipoIdentificacion</td>
                            <td>@cliente.Identificacion</td>
                            <td>@cliente.NombreCompleto</td>
                            <td>
                                @if (cliente.EstadoId == 1)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>
                            <td>
                                <a asp-page="./Edit" asp-route-id="@cliente.Id" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> Editar
                                </a>
                                <button type="button" class="btn btn-sm btn-danger"
                                        onclick="confirmarEliminacion(@cliente.Id, '@cliente.NombreCompleto')">
                                    <i class="fas fa-trash"></i> Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">No hay clientes registrados</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Paginación -->
    @if (Model.TotalPaginas > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PaginaActual == 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index" asp-route-pagina="@(Model.PaginaActual - 1)">Anterior</a>
                </li>
                @for (int i = 1; i <= Model.TotalPaginas; i++)
                {
                    <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                        <a class="page-link" asp-page="./Index" asp-route-pagina="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.PaginaActual == Model.TotalPaginas ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index" asp-route-pagina="@(Model.PaginaActual + 1)">Siguiente</a>
                </li>
            </ul>
        </nav>
    }
</div>

<!-- Modal de confirmación para eliminar -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Realmente desea eliminar el cliente <span id="clienteNombre" class="fw-bold"></span>?</p>
                <p class="text-danger">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">No</button>
                <form method="post" asp-page-handler="Delete" id="deleteForm">
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-danger">Sí, Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Función para confirmar eliminación
        function confirmarEliminacion(id, nombre) {
            document.getElementById('clienteNombre').textContent = nombre;
            document.getElementById('deleteId').value = id;
            var modal = new bootstrap.Modal(document.getElementById('deleteModal'));
            modal.show();
        }

        // Búsqueda en tiempo real
        document.getElementById('searchInput').addEventListener('keyup', function(e) {
            if (e.key === 'Enter') {
                buscar();
            }
        });

        document.getElementById('searchButton').addEventListener('click', buscar);
        document.getElementById('clearButton').addEventListener('click', limpiarBusqueda);

        function buscar() {
            var searchTerm = document.getElementById('searchInput').value.toLowerCase();
            var rows = document.querySelectorAll('#clientesTableBody tr');

            rows.forEach(function(row) {
                var nombre = row.cells[3]?.textContent.toLowerCase() || '';
                var identificacion = row.cells[2]?.textContent.toLowerCase() || '';

                if (nombre.includes(searchTerm) || identificacion.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        function limpiarBusqueda() {
            document.getElementById('searchInput').value = '';
            var rows = document.querySelectorAll('#clientesTableBody tr');
            rows.forEach(function(row) {
                row.style.display = '';
            });
        }
    </script>
}