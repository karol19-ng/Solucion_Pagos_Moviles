@model IEnumerable<Pegasos.Web.Administrador.Models.ClienteCoreViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Administración de Clientes - Core Bancario";
}

@Html.AntiForgeryToken()

@section Styles {
    <style>
        /* Estilos con la paleta del sistema */
        .page-header {
            background: linear-gradient(135deg, var(--vinotinto-sidebar) 0%, #4a0d1f 100%);
            border: 1px solid var(--dorado-primario);
            padding: 20px 30px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

            .page-header h1 {
                color: var(--dorado-primario);
                font-size: 1.8rem;
                font-weight: 600;
                margin: 0;
                text-shadow: 0 2px 4px rgba(0,0,0,0.3);
            }

            .page-header i {
                margin-right: 15px;
                color: var(--dorado-primario);
                font-size: 2rem;
            }

        /* Botón Nuevo Cliente */
        .btn-primary-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 10px 25px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

            .btn-primary-custom:hover {
                background: var(--dorado-primario);
                color: var(--vinotinto-sidebar);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(197, 163, 103, 0.3);
            }

            .btn-primary-custom i {
                margin-right: 8px;
                font-size: 1.1rem;
            }

        /* Notificaciones */
        #dynamicNotification {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
            max-width: 400px;
            padding: 15px 20px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            display: none;
            animation: slideIn 0.3s ease;
        }

        .notification-success {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            border-left: 4px solid #fff;
        }

        .notification-error {
            background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
            color: white;
            border-left: 4px solid #fff;
        }

        .close-btn {
            float: right;
            cursor: pointer;
            font-size: 1.2rem;
            opacity: 0.8;
            transition: opacity 0.3s;
            margin-left: 10px;
        }

            .close-btn:hover {
                opacity: 1;
            }

        @@keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Alertas temporales (TempData) */
        .alert-custom {
            border-radius: 6px;
            padding: 15px 20px;
            margin-bottom: 20px;
            border: 1px solid var(--dorado-primario);
            background: rgba(31, 6, 12, 0.8);
            color: white;
            backdrop-filter: blur(5px);
        }

        .alert-success-custom {
            border-left: 4px solid #28a745;
        }

        .alert-danger-custom {
            border-left: 4px solid #dc3545;
        }

        .alert i {
            margin-right: 10px;
        }

        /* Buscador */
        .search-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid rgba(197, 163, 103, 0.2);
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 25px;
            backdrop-filter: blur(5px);
        }

        .search-box {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 10px 15px;
            border-radius: 6px;
            font-size: 0.95rem;
            transition: all 0.3s ease;
        }

            .search-box:focus {
                background: rgba(255, 255, 255, 0.1);
                border-color: var(--dorado-primario);
                color: white;
                box-shadow: 0 0 0 3px rgba(197, 163, 103, 0.1);
                outline: none;
            }

            .search-box::placeholder {
                color: rgba(255, 255, 255, 0.5);
                font-style: italic;
            }

        .btn-search {
            background: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
            border: none;
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-search:hover {
                background: #d4b574;
                transform: translateY(-2px);
            }

        .btn-clear {
            background: transparent;
            color: white;
            border: 1px solid rgba(197, 163, 103, 0.3);
            padding: 10px 20px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-clear:hover {
                background: rgba(255, 255, 255, 0.1);
                border-color: var(--dorado-primario);
            }

        /* Tabla */
        .table-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid rgba(197, 163, 103, 0.2);
            border-radius: 8px;
            padding: 20px;
            backdrop-filter: blur(5px);
        }

        .table-custom {
            width: 100%;
            border-collapse: collapse;
        }

            .table-custom thead th {
                background: rgba(31, 6, 12, 0.8);
                color: var(--dorado-primario);
                padding: 12px 15px;
                font-weight: 600;
                font-size: 0.85rem;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                border-bottom: 2px solid var(--dorado-primario);
            }

            .table-custom tbody tr {
                border-bottom: 1px solid rgba(197, 163, 103, 0.1);
                transition: all 0.3s ease;
            }

                .table-custom tbody tr:hover {
                    background: rgba(197, 163, 103, 0.1);
                }

            .table-custom tbody td {
                padding: 12px 15px;
                color: rgba(255, 255, 255, 0.9);
            }

        /* Badges de estado */
        .badge-success {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            padding: 5px 10px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 0.75rem;
            border: 1px solid #28a745;
        }

        .badge-danger {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
            padding: 5px 10px;
            border-radius: 4px;
            font-weight: 600;
            font-size: 0.75rem;
            border: 1px solid #dc3545;
        }

        /* Botones de acción */
        .btn-action {
            width: 32px;
            height: 32px;
            border-radius: 4px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin: 0 3px;
            transition: all 0.3s ease;
            border: none;
            color: white;
            font-size: 0.9rem;
            text-decoration: none;
            cursor: pointer;
        }

        .btn-action-warning {
            background: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
        }

        .btn-action-danger {
            background: #dc3545;
        }

        .btn-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 10px rgba(0,0,0,0.3);
        }

        /* Paginación */
        .pagination-custom {
            margin-top: 25px;
        }

        .page-link {
            background: transparent;
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            margin: 0 3px;
            border-radius: 4px !important;
            transition: all 0.3s ease;
        }

            .page-link:hover {
                background: var(--dorado-primario);
                border-color: var(--dorado-primario);
                color: var(--vinotinto-sidebar);
            }

        .page-item.active .page-link {
            background: var(--dorado-primario);
            border-color: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
            font-weight: 600;
        }

        .page-item.disabled .page-link {
            opacity: 0.5;
            pointer-events: none;
        }

        /* No data */
        .no-data {
            text-align: center;
            padding: 40px;
            color: rgba(255, 255, 255, 0.5);
        }

            .no-data i {
                font-size: 3rem;
                margin-bottom: 15px;
                color: rgba(197, 163, 103, 0.3);
            }
    </style>
}

<div class="container-fluid mt-4">
    <!-- Header con título y botón -->
    <div class="page-header d-flex justify-content-between align-items-center">
        <h1>
            <i class="fas fa-id-card"></i>
            Clientes del Core Bancario
        </h1>
        <a href="/ClientesCore/Create" class="btn-primary-custom">
            <i class="fas fa-plus-circle"></i>
            Nuevo Cliente
        </a>
    </div>

    <!-- Mensajes de notificación (TempData) -->
    @if (TempData["Success"] != null)
    {
        <div class="alert-custom alert-success-custom alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-custom alert-danger-custom alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Buscador -->
    <div class="search-container">
        <div class="row">
            <div class="col-md-8">
                <div class="input-group">
                    <input type="text" id="searchTerm" class="form-control search-box"
                           placeholder="Buscar por nombre o identificación...">
                    <button class="btn-search" type="button" id="searchButton">
                        <i class="fas fa-search me-2"></i>Buscar
                    </button>
                    <button class="btn-clear" type="button" id="clearButton">
                        <i class="fas fa-times me-2"></i>Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de clientes -->
    <div class="table-container">
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Tipo ID</th>
                        <th>Identificación</th>
                        <th>Nombre Completo</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="clientesTableBody">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var cliente in Model)
                        {
                            <tr>
                                <td>#@cliente.Id</td>
                                <td>@cliente.TipoIdentificacion</td>
                                <td>@cliente.Identificacion</td>
                                <td>@cliente.NombreCompleto</td>
                                <td>
                                    @if (cliente.EstadoId == 1)
                                    {
                                        <span class="badge-success">ACTIVO</span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger">INACTIVO</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@cliente.Id"
                                       class="btn-action btn-action-warning"
                                       title="Editar cliente">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button type="button"
                                            class="btn-action btn-action-danger delete-btn"
                                            onclick="confirmarEliminacion(@cliente.Id, '@Html.Raw(cliente.NombreCompleto?.Replace("'", "\\'"))')"
                                            title="Eliminar cliente"
                                            data-id="@cliente.Id"
                                            data-nombre="@cliente.NombreCompleto">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="no-data">
                                <i class="fas fa-users-slash"></i>
                                No hay clientes registrados en el sistema
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        @if (ViewBag.TotalPaginas > 1)
        {
            <nav class="pagination-custom">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(ViewBag.PaginaActual == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual - 1)">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPaginas; i++)
                    {
                        <li class="page-item @(i == ViewBag.PaginaActual ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pagina="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.PaginaActual == ViewBag.TotalPaginas ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual + 1)">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Función para mostrar notificaciones
        function showNotification(type, message) {
            // Crear elemento de notificación si no existe
            let notification = $('#dynamicNotification');
            if (notification.length === 0) {
                $('body').append('<div id="dynamicNotification" class="notification"></div>');
                notification = $('#dynamicNotification');
            }

            // Configurar estilo según tipo
            notification.removeClass('notification-success notification-error');
            if (type === 'success') {
                notification.addClass('notification-success');
            } else {
                notification.addClass('notification-error');
            }

            // Mostrar mensaje
            notification.html('<i class="fas ' + (type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle') + ' me-2"></i>' + message + '<span class="close-btn" onclick="$(this).parent().fadeOut()">&times;</span>');
            notification.fadeIn(300);

            // Auto-cerrar después de 5 segundos
            setTimeout(function() {
                notification.fadeOut(300);
            }, 5000);
        }

        function confirmarEliminacion(id, nombre) {
            if (confirm('¿Está seguro que desea eliminar el cliente ' + nombre + '? Esta acción no se puede deshacer.')) {

                // Obtener el botón que se clickeó (usando el ID del cliente)
                var btn = $(`button[onclick*="confirmarEliminacion(${id}"]`);

                // Guardar el HTML original
                var originalHtml = btn.html();

                // Mostrar indicador de carga
                btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

                // Obtener token antiforgery
                var token = $('input[name="__RequestVerificationToken"]').first().val();

                $.ajax({
                    url: '/ClientesCore/Delete/' + id,
                    type: 'POST',
                    data: {
                        __RequestVerificationToken: token,
                        id: id
                    },
                    success: function(response) {
                        btn.prop('disabled', false).html(originalHtml);

                        if (response.success) {
                            showNotification('success', response.message);
                            // Recargar la tabla después de 1 segundo
                            setTimeout(function() {
                                location.reload();
                            }, 1000);
                        } else {
                            showNotification('error', response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        btn.prop('disabled', false).html(originalHtml);

                        // Intentar obtener el mensaje de error del servidor
                        var errorMsg = 'Error al eliminar';
                        try {
                            var response = JSON.parse(xhr.responseText);
                            if (response.message) {
                                errorMsg = response.message;
                            }
                        } catch(e) {
                            errorMsg = 'Error al eliminar: ' + error;
                        }

                        showNotification('error', errorMsg);
                        console.error('Error:', xhr.responseText);
                    }
                });
            }
        }

        $(document).ready(function() {
            // Búsqueda en tiempo real
            $('#searchTerm').on('keyup', function(e) {
                if (e.key === 'Enter') {
                    buscarClientes();
                }
            });

            $('#searchButton').click(buscarClientes);
            $('#clearButton').click(limpiarBusqueda);

            function buscarClientes() {
                var termino = $('#searchTerm').val();
                if (termino.length < 2 && termino.length > 0) return;

                $('#searchButton').html('<i class="fas fa-spinner fa-spin me-2"></i>Buscando...').prop('disabled', true);

                $.get('@Url.Action("Buscar", "ClientesCore")', { termino: termino }, function(data) {
                    var tbody = $('#clientesTableBody');
                    tbody.empty();

                    if (data && data.length > 0) {
                        $.each(data, function(i, cliente) {
                            var estadoBadge = cliente.estadoId == 1 ? 'badge-success' : 'badge-danger';
                            var estadoTexto = cliente.estadoId == 1 ? 'ACTIVO' : 'INACTIVO';

                            // Escapar comillas simples para JavaScript
                            var nombreSeguro = (cliente.nombreCompleto || '').replace(/'/g, "\\'");

                            var row = '<tr>' +
                                '<td>#' + cliente.id + '</td>' +
                                '<td>' + (cliente.tipoIdentificacion || '') + '</td>' +
                                '<td>' + (cliente.identificacion || '') + '</td>' +
                                '<td>' + (cliente.nombreCompleto || '') + '</td>' +
                                '<td><span class="' + estadoBadge + '">' + estadoTexto + '</span></td>' +
                                '<td>' +
                                '<a href="/ClientesCore/Edit/' + cliente.id + '" class="btn-action btn-action-warning" title="Editar cliente"><i class="fas fa-edit"></i></a> ' +
                                '<button type="button" class="btn-action btn-action-danger delete-btn" onclick="confirmarEliminacion(' + cliente.id + ', \'' + nombreSeguro + '\')" title="Eliminar cliente"><i class="fas fa-trash-alt"></i></button>' +
                                '</td>' +
                                '</tr>';
                            tbody.append(row);
                        });
                    } else {
                        tbody.append('<tr><td colspan="6" class="no-data"><i class="fas fa-search"></i> No se encontraron clientes con el término "' + termino + '"</td></tr>');
                    }
                }).always(function() {
                    $('#searchButton').html('<i class="fas fa-search me-2"></i>Buscar').prop('disabled', false);
                });
            }

            function limpiarBusqueda() {
                $('#searchTerm').val('');
                location.reload();
            }
        });
    </script>
}