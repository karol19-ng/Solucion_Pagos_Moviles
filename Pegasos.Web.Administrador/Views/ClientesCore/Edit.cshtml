<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-container">
                <div class="form-header">
                    <h4>
                        <i class="fas fa-user-edit"></i>
                        Editar Cliente #@Model.Id
                        @if (Model.EstadoId == 1)
                        {
                            <span class="estado-badge estado-activo">ACTIVO</span>
                        }
                        else
                        {
                            <span class="estado-badge estado-inactivo">INACTIVO</span>
                        }
                    </h4>
                </div>

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <strong>Modo Edición:</strong> Está modificando los datos del cliente. Los cambios se guardarán permanentemente.
                </div>

                <form asp-action="Edit" method="post" id="editForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="TipoIdentificacion" class="form-label">
                            <i class="fas fa-id-card"></i> Tipo de Identificación <span class="required-field"></span>
                        </label>
                        <select asp-for="TipoIdentificacion" class="form-select form-select-custom" id="TipoIdentificacion" name="TipoIdentificacion">
                            @foreach (var tipo in ViewBag.TiposIdentificacion)
                            {
                                <option value="@tipo" @(Model.TipoIdentificacion == tipo ? "selected" : "")>@tipo</option>
                            }
                        </select>
                        <span asp-validation-for="TipoIdentificacion" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Identificacion" class="form-label">
                            <i class="fas fa-hashtag"></i> Número de Identificación <span class="required-field"></span>
                        </label>
                        <input asp-for="Identificacion" class="form-control form-control-custom"
                               id="Identificacion" name="Identificacion"
                               value="@Model.Identificacion"
                               placeholder="Ej: 123456789" />
                        <span asp-validation-for="Identificacion" class="text-danger" id="identificacionError"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="NombreCompleto" class="form-label">
                            <i class="fas fa-user"></i> Nombre Completo <span class="required-field"></span>
                        </label>
                        <input asp-for="NombreCompleto" class="form-control form-control-custom"
                               id="NombreCompleto" name="NombreCompleto"
                               value="@Model.NombreCompleto"
                               placeholder="Ej: Juan Pérez González" />
                        <span asp-validation-for="NombreCompleto" class="text-danger" id="nombreError"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Telefono" class="form-label">
                            <i class="fas fa-phone"></i> Teléfono <span class="required-field"></span>
                        </label>
                        <input asp-for="Telefono" class="form-control form-control-custom"
                               id="Telefono" name="Telefono"
                               value="@Model.Telefono"
                               placeholder="Ej: 8888-8888" />
                        <span asp-validation-for="Telefono" class="text-danger" id="telefonoError"></span>
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i> Formato: 8888-8888 o 12345678
                        </small>
                    </div>

                    <div class="form-group">
                        <label asp-for="FechaNacimiento" class="form-label">
                            <i class="fas fa-calendar-alt"></i> Fecha de Nacimiento <span class="required-field"></span>
                        </label>
                        <input asp-for="FechaNacimiento" class="form-control form-control-custom"
                               id="FechaNacimiento" name="FechaNacimiento"
                               type="date"
                               value="@(Model.FechaNacimiento != DateTime.MinValue ? Model.FechaNacimiento.ToString("yyyy-MM-dd") : "")" />
                        <span asp-validation-for="FechaNacimiento" class="text-danger" id="fechaError"></span>
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i> Formato: DD/MM/AAAA
                        </small>
                    </div>

                    <div class="form-group">
                        <label asp-for="EstadoId" class="form-label">
                            <i class="fas fa-toggle-on"></i> Estado del Cliente
                        </label>
                        <select asp-for="EstadoId" class="form-select form-select-custom" id="EstadoId" name="EstadoId">
                            <option value="1">Activo - Cliente habilitado para operaciones</option>
                            <option value="2">Inactivo - Cliente bloqueado/deshabilitado</option>
                        </select>
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i> Los clientes inactivos no pueden realizar operaciones.
                        </small>
                    </div>

                    <div class="btn-container">
                        <a href="/ClientesCore/Index" class="btn-secondary-custom">
                            <i class="fas fa-arrow-left"></i> Regresar al Listado
                        </a>
                        <button type="submit" class="btn-warning-custom" id="btnGuardar">
                            <i class="fas fa-save"></i> Actualizar Cliente
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            // Validación en tiempo real
            $('#Identificacion').on('input', function() {
                var valor = $(this).val();
                if (!valor || valor.trim() === '') {
                    $('#identificacionError').text('La identificación es requerida');
                } else {
                    $('#identificacionError').text('');
                }
            });

            $('#NombreCompleto').on('input', function() {
                var valor = $(this).val();
                if (!valor || valor.trim() === '') {
                    $('#nombreError').text('El nombre completo es requerido');
                } else {
                    $('#nombreError').text('');
                }
            });

            // Validación de teléfono en tiempo real
            $('#Telefono').on('input', function() {
                var valor = $(this).val();
                var regexTelefono = /^[0-9\-\(\)\s]+$/;

                if (!valor || valor.trim() === '') {
                    $('#telefonoError').text('El teléfono es requerido');
                } else if (!regexTelefono.test(valor)) {
                    $('#telefonoError').text('El teléfono solo puede contener números, guiones y paréntesis');
                } else {
                    $('#telefonoError').text('');
                }
            });

            // 🆕 Validación de fecha en tiempo real
            $('#FechaNacimiento').on('change', function() {
                var valor = $(this).val();
                if (!valor) {
                    $('#fechaError').text('La fecha de nacimiento es requerida');
                } else {
                    var fecha = new Date(valor);
                    var hoy = new Date();
                    var edad = hoy.getFullYear() - fecha.getFullYear();
                    var mesDiff = hoy.getMonth() - fecha.getMonth();

                    if (mesDiff < 0 || (mesDiff === 0 && hoy.getDate() < fecha.getDate())) {
                        edad--;
                    }

                    if (edad < 18) {
                        $('#fechaError').text('El cliente debe ser mayor de 18 años');
                    } else if (edad > 100) {
                        $('#fechaError').text('Verifique la fecha de nacimiento');
                    } else {
                        $('#fechaError').text('');
                    }
                }
            });

            // Validación antes de enviar
            $('#editForm').submit(function(e) {
                var identificacion = $('#Identificacion').val();
                var nombre = $('#NombreCompleto').val();
                var telefono = $('#Telefono').val();
                var fecha = $('#FechaNacimiento').val();
                var errores = [];

                if (!identificacion || identificacion.trim() === '') {
                    errores.push('La identificación es requerida');
                    $('#identificacionError').text('La identificación es requerida');
                }

                if (!nombre || nombre.trim() === '') {
                    errores.push('El nombre completo es requerido');
                    $('#nombreError').text('El nombre completo es requerido');
                }

                if (!telefono || telefono.trim() === '') {
                    errores.push('El teléfono es requerido');
                    $('#telefonoError').text('El teléfono es requerido');
                }

                if (!fecha) {
                    errores.push('La fecha de nacimiento es requerida');
                    $('#fechaError').text('La fecha de nacimiento es requerida');
                }

                if (errores.length > 0) {
                    alert('Por favor complete todos los campos requeridos:\n- ' + errores.join('\n- '));
                    e.preventDefault();
                    return false;
                }

                return true;
            });

            // Confirmar cambios antes de salir
            var formModified = false;
            $('input, select').on('change keyup', function() {
                formModified = true;
            });

            $('a[asp-action="Index"]').click(function(e) {
                if (formModified) {
                    if (!confirm('¿Tiene cambios sin guardar. ¿Está seguro que desea salir?')) {
                        e.preventDefault();
                        return false;
                    }
                }
            });

            // Antes de enviar el formulario
            $('#editForm').submit(function(e) {
                console.log('=== DATOS DEL FORMULARIO ===');
                console.log('ID:', $('#Id').val());
                console.log('TipoIdentificacion:', $('#TipoIdentificacion').val());
                console.log('Identificacion:', $('#Identificacion').val());
                console.log('NombreCompleto:', $('#NombreCompleto').val());
                console.log('Teléfono:', $('#Telefono').val());
                console.log('FechaNacimiento:', $('#FechaNacimiento').val());
                console.log('EstadoId:', $('#EstadoId').val());

                // Mostrar indicador de carga
                $('#btnGuardar').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-2"></i>Guardando...');
            });

            // Mostrar mensajes de TempData
        @if (TempData["Success"] != null)
        {
            <text>
                    Swal.fire({
                        icon: 'success',
                        title: '¡Éxito!',
                        text: '@TempData["Success"]',
                        background: '#1f060c',
                        color: '#fff',
                        confirmButtonColor: '#c5a367',
                        timer: 2500,
                        showConfirmButton: true
                    });
            </text>
        }
        @if (TempData["Error"] != null)
        {
            <text>
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: '@TempData["Error"]',
                        background: '#1f060c',
                        color: '#fff',
                        confirmButtonColor: '#c5a367'
                    });
            </text>
        }
        });
    </script>
}