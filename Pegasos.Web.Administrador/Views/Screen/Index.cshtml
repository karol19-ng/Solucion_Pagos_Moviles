@using Pegasos.Web.Administrador.Models
@model PantallaViewModel
@{
    ViewData["Title"] = "Administración de Pantallas";
}

<link rel="stylesheet" href="~/css/screen-management.css" />

<div class="screen-container">
    <!-- Header con título y botón nuevo -->
    <div class="screen-header">
        <h1 class="screen-title">
            <i class="fas fa-table me-2"></i>Gestión de Pantallas
        </h1>
        <button type="button" class="btn-accion" onclick="abrirModalCrear()">
            <i class="fas fa-plus me-2"></i>Nueva Pantalla
        </button>
    </div>

    <!-- Mensajes de éxito/error -->
    @if (TempData["Exito"] != null)
    {
        <div class="screen-alert screen-alert-success">
            <i class="fas fa-check-circle me-2"></i>@TempData["Exito"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="screen-alert screen-alert-error">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        </div>
    }

    <!-- Buscador -->
    <div class="screen-search">
        <div class="input-group">
            <input type="text"
                   class="form-control"
                   id="buscador"
                   placeholder="Buscar por nombre de pantalla..."
                   value="@Model.FiltroNombre"
                   onkeyup="filtrarTabla()" />
            <button class="btn-search" type="button" onclick="filtrarTabla()">
                <i class="fas fa-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(Model.FiltroNombre))
            {
                <a href="@Url.Action("Index")" class="btn-search" style="border-radius: 0;">
                    <i class="fas fa-times"></i>
                </a>
            }
        </div>
    </div>

    <!-- Tabla de pantallas -->
    @if (Model.Pantallas.Any())
    {
        <div class="table-responsive">
            <table class="screen-table" id="tablaPantallas">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Ruta</th>
                        <th>Descripción</th>
                        <th style="width: 120px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pantalla in Model.Pantallas)
                    {
                        <tr data-nombre="@pantalla.Nombre.ToLower()">
                            <td>
                                <i class="fas fa-window me-2" style="color: var(--dorado-primario);"></i>
                                @pantalla.Nombre
                            </td>
                            <td><code>@pantalla.Ruta</code></td>
                            <td>
                                @if (!string.IsNullOrEmpty(pantalla.Descripcion))
                                {
                                    <span class="screen-badge">@pantalla.Descripcion</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <button class="btn-accion me-1"
                                        onclick="abrirModalEditar(@pantalla.ID_Pantalla, '@pantalla.Nombre', '@pantalla.Ruta', '@Html.Raw(pantalla.Descripcion?.Replace("'", "\\'"))')"
                                        title="Editar">
                                    <i class="fas fa-edit"></i>
                                </button>
                                <button class="btn-accion btn-accion-danger"
                                        onclick="confirmarEliminar(@pantalla.ID_Pantalla, '@pantalla.Nombre')"
                                        title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-table fa-4x mb-3" style="color: rgba(197, 163, 103, 0.3);"></i>
            <p style="color: rgba(255, 255, 255, 0.5);">No hay pantallas registradas</p>
        </div>
    }
</div>

<!-- Modal Crear/Editar -->
<div class="screen-modal" id="modalPantalla" style="display: none;">
    <div class="screen-modal-content">
        <div class="screen-modal-header">
            <h3 class="screen-modal-title" id="modalTitulo">Crear Pantalla</h3>
            <button type="button" class="btn-accion" onclick="cerrarModal()">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <form method="post" id="formPantalla">
            @Html.AntiForgeryToken()
            <input type="hidden" id="pantallaId" name="ID_Pantalla" value="0" />

            <div class="screen-form-group">
                <label class="screen-form-label" for="nombre">
                    <i class="fas fa-tag me-2"></i>Nombre *
                </label>
                <input type="text"
                       class="screen-form-control"
                       id="nombre"
                       name="Nombre"
                       required
                       maxlength="100"
                       placeholder="Ej: Gestión de Usuarios" />
                <span class="text-danger" id="errorNombre" style="font-size: 0.85rem;"></span>
            </div>

            <div class="screen-form-group">
                <label class="screen-form-label" for="ruta">
                    <i class="fas fa-link me-2"></i>Ruta *
                </label>
                <input type="text"
                       class="screen-form-control"
                       id="ruta"
                       name="Ruta"
                       required
                       maxlength="200"
                       placeholder="Ej: /Usuario/Index" />
                <span class="text-danger" id="errorRuta" style="font-size: 0.85rem;"></span>
            </div>

            <div class="screen-form-group">
                <label class="screen-form-label" for="descripcion">
                    <i class="fas fa-align-left me-2"></i>Descripción
                </label>
                <textarea class="screen-form-control"
                          id="descripcion"
                          name="Descripcion"
                          rows="3"
                          maxlength="255"
                          placeholder="Descripción opcional..."></textarea>
            </div>

            <div class="text-end" style="margin-top: 2rem;">
                <button type="button" class="btn-accion me-2" onclick="cerrarModal()">
                    Cancelar
                </button>
                <button type="submit" class="btn-accion" id="btnGuardar">
                    <i class="fas fa-save me-2"></i>Guardar
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Confirmar Eliminar -->
<div class="screen-modal" id="modalEliminar" style="display: none;">
    <div class="screen-modal-content">
        <div class="screen-modal-header">
            <h3 class="screen-modal-title">Confirmar Eliminación</h3>
            <button type="button" class="btn-accion" onclick="cerrarModalEliminar()">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="text-center py-4">
            <i class="fas fa-exclamation-triangle fa-4x mb-3" style="color: #dc3545;"></i>
            <p>¿Está seguro que desea eliminar la pantalla</p>
            <p><strong id="pantallaEliminarNombre" style="color: var(--dorado-primario);"></strong>?</p>
            <p class="text-muted small">Esta acción no se puede deshacer.</p>
        </div>

        <form method="post" action="@Url.Action("Delete", "Screen")" id="formEliminar">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="pantallaEliminarId" value="" />
            <div class="text-end">
                <button type="button" class="btn-accion me-2" onclick="cerrarModalEliminar()">
                    Cancelar
                </button>
                <button type="submit" class="btn-accion btn-accion-danger">
                    <i class="fas fa-trash me-2"></i>Eliminar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Filtrar tabla en tiempo real
        function filtrarTabla() {
            const filtro = document.getElementById('buscador').value.toLowerCase();
            const filas = document.querySelectorAll('#tablaPantallas tbody tr');

            filas.forEach(fila => {
                const nombre = fila.getAttribute('data-nombre') || '';
                if (nombre.includes(filtro)) {
                    fila.style.display = '';
                } else {
                    fila.style.display = 'none';
                }
            });
        }

        // Abrir modal para crear
        function abrirModalCrear() {
            document.getElementById('modalTitulo').textContent = 'Crear Pantalla';
            document.getElementById('pantallaId').value = '0';
            document.getElementById('nombre').value = '';
            document.getElementById('ruta').value = '';
            document.getElementById('descripcion').value = '';
            document.getElementById('formPantalla').action = '@Url.Action("Create", "Screen")';

            // Limpiar errores
            document.getElementById('errorNombre').textContent = '';
            document.getElementById('errorRuta').textContent = '';

            document.getElementById('modalPantalla').style.display = 'flex';
        }

        // Abrir modal para editar
        function abrirModalEditar(id, nombre, ruta, descripcion) {
            document.getElementById('modalTitulo').textContent = 'Editar Pantalla';
            document.getElementById('pantallaId').value = id;
            document.getElementById('nombre').value = nombre;
            document.getElementById('ruta').value = ruta;
            document.getElementById('descripcion').value = descripcion || '';
            document.getElementById('formPantalla').action = '@Url.Action("Edit", "Screen")/' + id;

            // Limpiar errores
            document.getElementById('errorNombre').textContent = '';
            document.getElementById('errorRuta').textContent = '';

            document.getElementById('modalPantalla').style.display = 'flex';
        }

        // Cerrar modal
        function cerrarModal() {
            document.getElementById('modalPantalla').style.display = 'none';
        }

        // Confirmar eliminación
        function confirmarEliminar(id, nombre) {
            document.getElementById('pantallaEliminarId').value = id;
            document.getElementById('pantallaEliminarNombre').textContent = nombre;
            document.getElementById('modalEliminar').style.display = 'flex';
        }

        // Cerrar modal de eliminación
        function cerrarModalEliminar() {
            document.getElementById('modalEliminar').style.display = 'none';
        }

        // Validación del lado del cliente
        document.getElementById('formPantalla').addEventListener('submit', function(e) {
            let valido = true;
            const nombre = document.getElementById('nombre').value.trim();
            const ruta = document.getElementById('ruta').value.trim();

            document.getElementById('errorNombre').textContent = '';
            document.getElementById('errorRuta').textContent = '';

            if (!nombre) {
                document.getElementById('errorNombre').textContent = 'El nombre es obligatorio';
                valido = false;
            }

            if (!ruta) {
                document.getElementById('errorRuta').textContent = 'La ruta es obligatoria';
                valido = false;
            }

            if (!valido) {
                e.preventDefault();
            }
        });

        // Cerrar modales con Escape
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                cerrarModal();
                cerrarModalEliminar();
            }
        });

        // Cerrar modales haciendo clic fuera
        window.onclick = function(event) {
            const modalPantalla = document.getElementById('modalPantalla');
            const modalEliminar = document.getElementById('modalEliminar');

            if (event.target === modalPantalla) {
                cerrarModal();
            }
            if (event.target === modalEliminar) {
                cerrarModalEliminar();
            }
        }
    </script>
}