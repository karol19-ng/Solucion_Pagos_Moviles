﻿
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pegasos Bank</title>

    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
            :root {
                --sidebar-width: 260px;
                --vinotinto-sidebar: #1f060c;
                --vinotinto-fondo: #2b0811;
                --dorado-primario: #c5a367;
                --dorado-suave: rgba(197, 163, 103, 0.15);
                --texto-sidebar: rgba(255, 255, 255, 0.8);
            }

            body {
                margin: 0;
                background-color: var(--vinotinto-fondo);
                font-family: 'Montserrat', sans-serif;
                color: white;
                display: flex;
                min-height: 100vh;
            }

            /* BARRA LATERAL */
            .sidebar {
                width: var(--sidebar-width);
                height: 100vh;
                background-color: var(--vinotinto-sidebar);
                border-right: 1px solid rgba(197, 163, 103, 0.2);
                display: flex;
                flex-direction: column;
                position: fixed;
                z-index: 1000;
            }

            .sidebar-header {
                padding: 2rem 1.5rem;
                text-align: center;
                border-bottom: 1px solid rgba(197, 163, 103, 0.1);
            }

            .sidebar-logo {
                width: 70px;
                margin-bottom: 10px;
                filter: drop-shadow(0 0 5px var(--dorado-primario));
            }

            .sidebar-title {
                font-family: 'Cinzel', serif;
                color: var(--dorado-primario);
                font-size: 1rem;
                letter-spacing: 2px;
            }

            /* MENÚ DE NAVEGACIÓN */
            .sidebar-menu {
                flex-grow: 1;
                padding: 1.5rem 0;
                overflow-y: auto;
            }

            .menu-section-title {
                font-size: 0.65rem;
                text-transform: uppercase;
                letter-spacing: 2px;
                color: var(--dorado-primario);
                padding: 0 1.5rem;
                margin-bottom: 10px;
                opacity: 0.7;
            }

            .menu-item {
                display: flex;
                align-items: center;
                padding: 0.8rem 1.5rem;
                color: var(--texto-sidebar);
                text-decoration: none;
                transition: all 0.3s;
                border-left: 3px solid transparent;
                font-size: 0.85rem;
            }

                .menu-item i {
                    margin-right: 12px;
                    width: 20px;
                    text-align: center;
                    color: var(--dorado-primario);
                }

                .menu-item:hover {
                    background-color: var(--dorado-suave);
                    color: white;
                    border-left-color: var(--dorado-primario);
                    text-decoration: none;
                }

            /* CONTENIDO PRINCIPAL */
            .main-wrapper {
                margin-left: var(--sidebar-width);
                flex-grow: 1;
                display: flex;
                flex-direction: column;
            }

            .top-user-bar {
                background-color: rgba(31, 6, 12, 0.5);
                display: flex;
                justify-content: flex-end;
                align-items: center;
                padding: 1rem 2rem;
                border-bottom: 1px solid rgba(197, 163, 103, 0.1);
                backdrop-filter: blur(5px);
            }

            .main-content {
                padding: 2rem;
                flex-grow: 1;
            }

            .crud-container {
                background: rgba(255, 255, 255, 0.03);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(197, 163, 103, 0.2);
                border-radius: 12px;
                padding: 2rem;
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            }

            footer {
                padding: 1rem 2rem;
                background: rgba(0,0,0,0.2);
                font-size: 0.8rem;
                border-top: 1px solid rgba(197, 163, 103, 0.1);
            }

            .avatar-circle {
                background-image: url('/images/default.jpg');
                background-size: cover;
                background-position: center;
                background-color: var(--vinotinto-sidebar);
            }

            .user-profile-sidebar {
                padding: 20px;
                text-align: center;
                border-bottom: 1px solid rgba(197, 163, 103, 0.1);
            }

            .avatar-circle {
                width: 70px;
                height: 70px;
                margin: 0 auto;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                border: 2px solid var(--dorado-primario);
                background-size: cover;
                background-position: center;
            }

            .initials {
                font-size: 2rem;
                font-weight: bold;
                color: var(--dorado-primario);
            }
    </style>
</head>
<body>

    @{
        // Lógica para el Avatar
        var userClaims = User.Identity as System.Security.Claims.ClaimsIdentity;
        var nombreCompleto = userClaims?.FindFirst("nombreCompleto")?.Value ?? User.Identity?.Name ?? "Usuario";
        var inicial = !string.IsNullOrEmpty(nombreCompleto) ? nombreCompleto[0].ToString().ToUpper() : "P";

        var avatarUrl = "";
        if (User.Identity?.Name?.ToLower() == "sebastian")
        {
            avatarUrl = "/images/admin.jpg";
        }
    }

    <aside class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo_pegasos.png" class="sidebar-logo" alt="Pegasos Logo">
            <div class="sidebar-title">PEGASOS BANK</div>
        </div>

        <div class="user-profile-sidebar">
            <div class="avatar-circle" style="@(!string.IsNullOrEmpty(avatarUrl) ? $"background-image: url('{avatarUrl}');" : "")">
                @if (string.IsNullOrEmpty(avatarUrl))
                {
                    <span class="initials">
                        @inicial
                    </span>
                }
            </div>
            <div class="user-info-name" style="margin-top: 10px; font-weight: 600;">@nombreCompleto</div>
            <div class="user-info-role" style="color: var(--dorado-primario); font-size: 0.7rem; text-transform: uppercase;">
                @userClaims?.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
            </div>
        </div>

        <nav class="sidebar-menu">
            <p class="menu-section-title">Administración</p>
            <a href="@Url.Action("Index", "Clientes")" class="menu-item">
                <i class="fas fa-users"></i> Usuarios
            </a>
            <a href="@Url.Action("Index", "Roles")" class="menu-item">
                <i class="fas fa-user-tag"></i> Roles (SA7)
            </a>
            <a href="@Url.Action("Index", "Parametros")" class="menu-item">
                <i class="fas fa-sliders-h"></i> Parámetros
            </a>

            <!-- CLIENTES CORE - NUEVA OPCIÓN -->
            <a href="@Url.Action("Index", "ClientesCore")" class="menu-item">
                <i class="fas fa-id-card"></i> Clientes Core (SA10)
            </a>

            <a href="@Url.Action("Index", "CuentasCore")" class="menu-item">
                <i class="fas fa-credit-card"></i> Cuentas Core (SA11)
            </a>

            <p class="menu-section-title" style="margin-top: 20px;">Operaciones</p>
            <a href="@Url.Action("Index", "Entidades")" class="menu-item">
                <i class="fas fa-university"></i> Entidades
            </a>
            <a href="@Url.Action("Index", "Afiliaciones")" class="menu-item">
                <i class="fas fa-mobile-alt"></i> Pagos Móviles
            </a>

            <p class="menu-section-title" style="margin-top: 20px;">Seguridad</p>
            <a href="@Url.Action("Index", "Pantallas")" class="menu-item">
                <i class="fas fa-desktop"></i> Pantallas (SA6)
            </a>
            <a href="@Url.Action("Index", "Bitacora")" class="menu-item">
                <i class="fas fa-history"></i> Bitácora
            </a>
            <a href="@Url.Action("Logout", "Auth")" class="menu-item text-danger">
                <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
            </a>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="top-user-bar">
            <div class="me-auto ms-3">
                <span class="badge bg-danger">
                    <i class="fas fa-stopwatch me-1"></i> Sesión: <span id="timerDisplay">05:00</span>
                </span>
            </div>
            <span>
                <i class="fas fa-user-circle me-2" style="color: var(--dorado-primario)"></i>
                Usuario: <strong>@User.Identity?.Name</strong>
            </span>
        </header>

        <main role="main" class="main-content">
            <div class="crud-container">
                @RenderBody()
            </div>
        </main>

        <footer class="text-muted">
            <div class="container-fluid">
                &copy; 2026 - Pegasos Bank - Sistema Administrativo v2.0
            </div>
        </footer>
    </div>

    <!-- ========== MODALES GLOBALES ========== -->
    <!-- Modal de Confirmación Moderno -->
    <div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: linear-gradient(135deg, #1f060c 0%, #2a0a12 100%); border: 2px solid #c5a367; border-radius: 12px;">
                <div class="modal-header" style="border-bottom: 1px solid rgba(197, 163, 103, 0.3);">
                    <h5 class="modal-title" id="confirmModalLabel" style="color: #c5a367;">
                        <i class="fas fa-trash-alt me-2"></i>Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="color: white; padding: 25px;">
                    <div class="text-center mb-3">
                        <i class="fas fa-exclamation-triangle" style="font-size: 48px; color: #dc3545;"></i>
                    </div>
                    <p id="confirmModalMessage" class="text-center" style="font-size: 1.1rem;">
                        ¿Está seguro que desea eliminar este elemento?
                    </p>
                    <p class="text-center text-muted small mt-2">
                        Esta acción no se puede deshacer.
                    </p>
                </div>
                <div class="modal-footer" style="border-top: 1px solid rgba(197, 163, 103, 0.3); justify-content: center; gap: 15px;">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="background: transparent; border: 1px solid rgba(197, 163, 103, 0.5); color: white; padding: 8px 25px; border-radius: 6px;">
                        <i class="fas fa-times me-2"></i>Cancelar
                    </button>
                    <button type="button" class="btn btn-danger" id="confirmModalConfirmBtn" style="background: #dc3545; border: none; padding: 8px 25px; border-radius: 6px;">
                        <i class="fas fa-trash-alt me-2"></i>Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de Error Moderno -->
    <div class="modal fade" id="errorModal" tabindex="-1" aria-labelledby="errorModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: linear-gradient(135deg, #1f060c 0%, #2a0a12 100%); border: 2px solid #dc3545; border-radius: 12px;">
                <div class="modal-header" style="border-bottom: 1px solid rgba(220, 53, 69, 0.3);">
                    <h5 class="modal-title" id="errorModalLabel" style="color: #dc3545;">
                        <i class="fas fa-exclamation-circle me-2"></i>Error de Operación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="color: white; padding: 25px;">
                    <div class="text-center mb-3">
                        <i class="fas fa-times-circle" style="font-size: 48px; color: #dc3545;"></i>
                    </div>
                    <p id="errorModalMessage" class="text-center" style="font-size: 1rem;">
                        Ha ocurrido un error al procesar la solicitud.
                    </p>
                </div>
                <div class="modal-footer" style="border-top: 1px solid rgba(220, 53, 69, 0.3); justify-content: center;">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal" style="background: #c5a367; border: none; color: #1f060c; padding: 8px 30px; border-radius: 6px;">
                        <i class="fas fa-check me-2"></i>Entendido
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de Éxito Moderno -->
    <div class="modal fade" id="successModal" tabindex="-1" aria-labelledby="successModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background: linear-gradient(135deg, #1f060c 0%, #2a0a12 100%); border: 2px solid #28a745; border-radius: 12px;">
                <div class="modal-header" style="border-bottom: 1px solid rgba(40, 167, 69, 0.3);">
                    <h5 class="modal-title" id="successModalLabel" style="color: #28a745;">
                        <i class="fas fa-check-circle me-2"></i>Operación Exitosa
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="color: white; padding: 25px;">
                    <div class="text-center mb-3">
                        <i class="fas fa-check-circle" style="font-size: 48px; color: #28a745;"></i>
                    </div>
                    <p id="successModalMessage" class="text-center" style="font-size: 1rem;">
                        Operación realizada exitosamente.
                    </p>
                </div>
                <div class="modal-footer" style="border-top: 1px solid rgba(40, 167, 69, 0.3); justify-content: center;">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal" style="background: #c5a367; border: none; color: #1f060c; padding: 8px 30px; border-radius: 6px;">
                        <i class="fas fa-check me-2"></i>Aceptar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de Carga (Loading) -->
    <div class="modal fade" id="loadingModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="loadingModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content" style="background: linear-gradient(135deg, #1f060c 0%, #2a0a12 100%); border: 2px solid #c5a367; border-radius: 12px;">
                <div class="modal-body text-center py-4">
                    <div class="spinner-border text-warning mb-3" role="status" style="color: #c5a367; width: 40px; height: 40px;">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p style="color: white; margin: 0;">Procesando solicitud...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de Advertencia de Sesión (existente) -->
    <div class="modal fade" id="sessionModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content" style="background: #1f060c; border: 1px solid var(--dorado-primario); color: white;">
                <div class="modal-body text-center p-4">
                    <i class="fas fa-clock fa-3x mb-3" style="color: var(--dorado-primario);"></i>
                    <h4>Tu sesión está por expirar</h4>
                    <p>Por seguridad, tu sesión en Pegasos Bank finalizará pronto.</p>
                    <h2 style="color: var(--dorado-primario); font-family: 'Cinzel', serif;">Aviso de Seguridad</h2>
                    <button onclick="extendSession()" class="btn btn-warning mt-3">Continuar Trabajando</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Scripts Globales para Modales -->
    <script>
            // Variables globales para los modales
            let pendingConfirmAction = null;
        
            // Función para mostrar modal de confirmación
            window.showConfirmModal = function(message, onConfirm, itemName = '', confirmButtonText = 'Eliminar') {
                const modalElement = document.getElementById('confirmModal');
                const modal = new bootstrap.Modal(modalElement);
                const modalMessage = document.getElementById('confirmModalMessage');
                const confirmBtn = document.getElementById('confirmModalConfirmBtn');
            
                // Personalizar mensaje
                if (itemName) {
                    modalMessage.innerHTML = `<i class="fas fa-credit-card me-2"></i>¿Está seguro que desea eliminar <strong>${itemName}</strong>?<br><span class="text-muted small mt-2 d-block">Esta acción no se puede deshacer.</span>`;
                } else {
                    modalMessage.innerHTML = message;
                }
            
                // Personalizar texto del botón
                confirmBtn.innerHTML = `<i class="fas fa-trash-alt me-2"></i>${confirmButtonText}`;
            
                // Remover event listener anterior
                const newConfirmBtn = confirmBtn.cloneNode(true);
                confirmBtn.parentNode.replaceChild(newConfirmBtn, confirmBtn);
            
                // Agregar nuevo event listener
                newConfirmBtn.addEventListener('click', function() {
                    modal.hide();
                    if (onConfirm) onConfirm();
                });
            
                modal.show();
            };
        
            // Función para mostrar modal de error
            window.showErrorModal = function(message) {
                const modalElement = document.getElementById('errorModal');
                const modal = new bootstrap.Modal(modalElement);
                const modalMessage = document.getElementById('errorModalMessage');
            
                modalMessage.innerHTML = `<i class="fas fa-exclamation-triangle me-2"></i>${message}`;
                modal.show();
            };
        
            // Función para mostrar modal de éxito
            window.showSuccessModal = function(message, redirectUrl = null) {
                const modalElement = document.getElementById('successModal');
                const modal = new bootstrap.Modal(modalElement);
                const modalMessage = document.getElementById('successModalMessage');
            
                modalMessage.innerHTML = `<i class="fas fa-check-circle me-2"></i>${message}`;
                modal.show();
            
                // Redirigir si se especifica URL
                if (redirectUrl) {
                    modalElement.addEventListener('hidden.bs.modal', function() {
                        window.location.href = redirectUrl;
                    }, { once: true });
                }
            };
        
            // Función para mostrar modal de carga
            window.showLoadingModal = function() {
                const modalElement = document.getElementById('loadingModal');
                const modal = new bootstrap.Modal(modalElement);
                modal.show();
                return modal;
            };
        
            // Función para ocultar modal de carga
            window.hideLoadingModal = function(modal) {
                if (modal) modal.hide();
            };
        
            // Función para mostrar error de Gateway
            window.showGatewayError = function() {
                showErrorModal('Error del Gateway: BadGateway - No se pudo conectar con el servidor. Por favor, intente nuevamente.');
            };
        
            // Función para mostrar notificación Toast (alternativa ligera)
            window.showToast = function(message, type = 'success', duration = 3000) {
                // Crear contenedor de toasts si no existe
                let toastContainer = document.querySelector('.toast-container-global');
                if (!toastContainer) {
                    toastContainer = document.createElement('div');
                    toastContainer.className = 'toast-container-global';
                    toastContainer.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999;';
                    document.body.appendChild(toastContainer);
                }
            
                const toastId = 'toast-' + Date.now();
                const icon = type === 'success' ? 'fa-check-circle' : (type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle');
                const iconColor = type === 'success' ? '#28a745' : (type === 'error' ? '#dc3545' : '#c5a367');
            
                const toastHtml = `
                    <div id="${toastId}" class="toast custom-toast" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="${duration}" style="background: linear-gradient(135deg, #1f060c 0%, #2a0a12 100%); border: 1px solid ${iconColor}; border-radius: 8px; margin-bottom: 10px; min-width: 300px;">
                        <div class="toast-header" style="background: rgba(0,0,0,0.3); color: ${iconColor}; border-bottom: 1px solid ${iconColor};">
                            <i class="fas ${icon} me-2" style="color: ${iconColor}"></i>
                            <strong class="me-auto">${type === 'success' ? 'Éxito' : (type === 'error' ? 'Error' : 'Información')}</strong>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                        <div class="toast-body" style="color: white;">
                            ${message}
                        </div>
                    </div>
                `;
            
                toastContainer.insertAdjacentHTML('beforeend', toastHtml);
                const toastElement = document.getElementById(toastId);
                const toast = new bootstrap.Toast(toastElement, { delay: duration });
                toast.show();
            
                // Remover del DOM después de ocultarse
                toastElement.addEventListener('hidden.bs.toast', function() {
                    this.remove();
                });
            };
    </script>

    <!-- Script de Control de Sesión -->
    <script>
            let timeLeft = 300;

            document.addEventListener("DOMContentLoaded", function() {
                const timerElement = document.getElementById('timerDisplay');
                const modalEl = document.getElementById('sessionModal');
                const sessionModal = (modalEl && typeof bootstrap !== 'undefined') ? new bootstrap.Modal(modalEl) : null;

                const countdown = setInterval(() => {
                    if (timeLeft <= 0) {
                        clearInterval(countdown);
                        window.location.href = '/Auth/Logout?expired=true';
                    } else {
                        timeLeft--;
                        let minutes = Math.floor(timeLeft / 60);
                        let seconds = timeLeft % 60;

                        if(timerElement) {
                            timerElement.innerHTML = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                        }

                        if (timeLeft === 60 && sessionModal) {
                            sessionModal.show();
                        }
                    }
                }, 1000);
            });

            async function extendSession() {
                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                    const response = await fetch('/Auth/ExtendSession', {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token }
                    });

                    if (response.ok) {
                        timeLeft = 300;
                        console.log("Sesión extendida");
                        const modalEl = document.getElementById('sessionModal');
                        const modalInstance = bootstrap.Modal.getInstance(modalEl);
                        if (modalInstance) modalInstance.hide();
                    }
                } catch (e) { console.error("Error al extender:", e); }
            }
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/session-control.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>