<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pegasos Bank</title>

    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
        :root {
            --sidebar-width: 260px;
            --vinotinto-sidebar: #1f060c;
            --vinotinto-fondo: #2b0811;
            --dorado-primario: #c5a367;
            --dorado-suave: rgba(197, 163, 103, 0.15);
            --texto-sidebar: rgba(255, 255, 255, 0.8);
        }

        body {
            margin: 0;
            background-color: var(--vinotinto-fondo);
            font-family: 'Montserrat', sans-serif;
            color: white;
            display: flex;
            min-height: 100vh;
        }

        /* BARRA LATERAL */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            background-color: var(--vinotinto-sidebar);
            border-right: 1px solid rgba(197, 163, 103, 0.2);
            display: flex;
            flex-direction: column;
            position: fixed;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 2rem 1.5rem;
            text-align: center;
            border-bottom: 1px solid rgba(197, 163, 103, 0.1);
        }

        .sidebar-logo {
            width: 70px;
            margin-bottom: 10px;
            filter: drop-shadow(0 0 5px var(--dorado-primario));
        }

        .sidebar-title {
            font-family: 'Cinzel', serif;
            color: var(--dorado-primario);
            font-size: 1rem;
            letter-spacing: 2px;
        }

        /* MENÚ DE NAVEGACIÓN */
        .sidebar-menu {
            flex-grow: 1;
            padding: 1.5rem 0;
            overflow-y: auto;
        }

        .menu-section-title {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: var(--dorado-primario);
            padding: 0 1.5rem;
            margin-bottom: 10px;
            opacity: 0.7;
        }

        .menu-item {
            display: flex;
            align-items: center;
            padding: 0.8rem 1.5rem;
            color: var(--texto-sidebar);
            text-decoration: none;
            transition: all 0.3s;
            border-left: 3px solid transparent;
            font-size: 0.85rem;
        }

            .menu-item i {
                margin-right: 12px;
                width: 20px;
                text-align: center;
                color: var(--dorado-primario);
            }

            .menu-item:hover {
                background-color: var(--dorado-suave);
                color: white;
                border-left-color: var(--dorado-primario);
                text-decoration: none;
            }

        /* CONTENIDO PRINCIPAL */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        .top-user-bar {
            background-color: rgba(31, 6, 12, 0.5);
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 1rem 2rem;
            border-bottom: 1px solid rgba(197, 163, 103, 0.1);
            backdrop-filter: blur(5px);
        }

        .main-content {
            padding: 2rem;
            flex-grow: 1;
        }

        .crud-container {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(197, 163, 103, 0.2);
            border-radius: 12px;
            padding: 2rem;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }

        footer {
            padding: 1rem 2rem;
            background: rgba(0,0,0,0.2);
            font-size: 0.8rem;
            border-top: 1px solid rgba(197, 163, 103, 0.1);
        }

        .avatar-circle {
            background-image: url('/images/default.jpg'); /* Imagen por defecto */
            background-size: cover;
            background-position: center;
            /* Si la imagen no carga, el color de fondo y la inicial  */
            background-color: var(--vinotinto-sidebar);
        }
    </style>
</head>
<body>

    @{
        // Lógica para el Avatar
        var userClaims = User.Identity as System.Security.Claims.ClaimsIdentity;
        var nombreCompleto = userClaims?.FindFirst("nombreCompleto")?.Value ?? User.Identity?.Name ?? "Usuario";
        var inicial = !string.IsNullOrEmpty(nombreCompleto) ? nombreCompleto[0].ToString().ToUpper() : "P";

        var avatarUrl = "";
        if (User.Identity?.Name?.ToLower() == "sebastian")
        {
            avatarUrl = "/images/admin.jpg"; 
        }
    }

    <aside class="sidebar">
        <div class="sidebar-header">
            <img src="/images/logo_pegasos.png" class="sidebar-logo" alt="Pegasos Logo">
            <div class="sidebar-title">PEGASOS BANK</div>
        </div>

        <div class="user-profile-sidebar text-center">

            <div class="avatar-circle" style="@(!string.IsNullOrEmpty(avatarUrl) ? $"background-image: url('{avatarUrl}');" : "")">
                @if (string.IsNullOrEmpty(avatarUrl))
                {
                    <span class="initials" style="font-family: 'Cinzel', serif; color: var(--dorado-primario); font-size: 1.8rem; font-weight: bold;">
                        @inicial
                    </span>
                }
            </div>
            <div class="user-info-name" style="margin-top: 10px; font-weight: 600;">@nombreCompleto</div>
            <div class="user-info-role" style="color: var(--dorado-primario); font-size: 0.7rem; text-transform: uppercase;">
                @userClaims?.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
            </div>
        </div>

        <nav class="sidebar-menu">
            <p class="menu-section-title">Administración</p>
            <a href="@Url.Action("Index", "Clientes")" class="menu-item">
                <i class="fas fa-users"></i> Usuarios 
            </a>
            <a href="@Url.Action("Index", "Roles")" class="menu-item">
                <i class="fas fa-user-tag"></i> Roles 
            </a>
            <a href="@Url.Action("Index", "Parametros")" class="menu-item">
                <i class="fas fa-sliders-h"></i> Parámetros
            </a>

            <p class="menu-section-title" style="margin-top: 20px;">Operaciones</p>
            <a href="@Url.Action("Index", "Entidades")" class="menu-item">
                <i class="fas fa-university"></i> Entidades 
            </a>
            <a href="@Url.Action("Index", "Afiliaciones")" class="menu-item">
                <i class="fas fa-mobile-alt"></i> Pagos Móviles
            </a>

            <p class="menu-section-title" style="margin-top: 20px;">Seguridad</p>
            <a href="@Url.Action("Index", "Bitacora")" class="menu-item">
                <i class="fas fa-history"></i> Bitácora 
            </a>
            <a href="@Url.Action("Logout", "Auth")" class="menu-item text-danger">
                <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
            </a>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="top-user-bar">
            <span>
                <i class="fas fa-user-circle me-2" style="color: var(--dorado-primario)"></i>
                Usuario: <strong>@User.Identity?.Name</strong>
            </span>
        </header>

        <main role="main" class="main-content">
            <div class="crud-container">
                @RenderBody()
            </div>
        </main>

        <footer class="text-muted">
            <div class="container-fluid">
                &copy; 2026 - Pegasos Bank - Sistema Administrativo v2.0
            </div>
        </footer>
    </div>




    <div class="top-user-bar">
        <div class="me-auto ms-3">
            <span class="badge bg-danger">
                <i class="fas fa-stopwatch me-1"></i> Sesión: <span id="timerDisplay">05:00</span>
            </span>
        </div>
    </div>

    <div class="modal fade" id="sessionModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content" style="background: #1f060c; border: 1px solid var(--dorado-primario); color: white;">
                <div class="modal-body text-center p-4">
                    <i class="fas fa-clock fa-3x mb-3" style="color: var(--dorado-primario);"></i>
                    <h4>Tu sesión está por expirar</h4>
                    <p>Por seguridad, tu sesión en Pegasos Bank finalizará pronto.</p>
                    <h2 style="color: var(--dorado-primario); font-family: 'Cinzel', serif;">Aviso de Seguridad</h2>
                    <button onclick="extendSession()" class="btn btn-warning mt-3">Continuar Trabajando</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let timeLeft = 300;

        document.addEventListener("DOMContentLoaded", function() {
            const timerElement = document.getElementById('timerDisplay');
            const modalEl = document.getElementById('sessionModal');
            // Verificamos que bootstrap esté cargado
            const sessionModal = (modalEl && typeof bootstrap !== 'undefined') ? new bootstrap.Modal(modalEl) : null;

            const countdown = setInterval(() => {
                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    window.location.href = '/Auth/Logout?expired=true';
                } else {
                    timeLeft--;
                    let minutes = Math.floor(timeLeft / 60);
                    let seconds = timeLeft % 60;

                    if(timerElement) {
                        timerElement.innerHTML = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
                    }

                    if (timeLeft === 60 && sessionModal) {
                        sessionModal.show();
                    }
                }
            }, 1000);
        });

        async function extendSession() {
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch('/Auth/ExtendSession', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token }
                });

                if (response.ok) {
                    timeLeft = 300;
                    console.log("Sesión extendida");
                    const modalEl = document.getElementById('sessionModal');
                    const modalInstance = bootstrap.Modal.getInstance(modalEl);
                    if (modalInstance) modalInstance.hide();
                }
            } catch (e) { console.error("Error al extender:", e); }
        }
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/session-control.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>