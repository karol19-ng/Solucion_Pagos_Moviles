@using System.Security.Claims

<header class="nexus-topbar">
    <button class="nexus-sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
        <i class="fas fa-bars"></i>
    </button>

    <div class="nexus-breadcrumb">
        <span class="nexus-page-title">@ViewData["Title"]</span>
    </div>

    <div class="nexus-topbar-actions">
        <!-- SA4: Session timer indicator -->
        <div class="nexus-session-indicator" id="sessionIndicator" title="Tiempo restante de sesión">
            <i class="fas fa-clock"></i>
            <span id="sessionTimer">05:00</span>
        </div>

        <div class="nexus-user-menu">
            <button class="nexus-user-dropdown-toggle" id="userDropdownToggle">
                <div class="nexus-avatar">
                    <i class="fas fa-user-circle"></i>
                </div>
                <div class="nexus-user-info">
                    <span class="nexus-user-name">@User.FindFirst("nombreCompleto")?.Value</span>
                    <span class="nexus-user-role">@User.FindFirst(ClaimTypes.Role)?.Value</span>
                </div>
                <i class="fas fa-chevron-down nexus-dropdown-icon"></i>
            </button>

            <div class="nexus-dropdown-menu" id="userDropdownMenu">
                <div class="nexus-dropdown-header">
                    <strong>@User.Identity?.Name</strong>
                </div>
                <div class="nexus-dropdown-divider"></div>
                <a href="/Auth/Logout" class="nexus-dropdown-item">
                    <i class="fas fa-sign-out-alt"></i> Cerrar sesión
                </a>
            </div>
        </div>
    </div>
</header>