@model Pegasos.Web.Administrador.Models.EditarCuentaCoreViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Editar Cuenta";
}

@section Styles {
    <style>
        .form-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid var(--dorado-primario);
            border-radius: 8px;
            padding: 30px;
            backdrop-filter: blur(5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }
        .form-header {
            background: linear-gradient(135deg, var(--vinotinto-sidebar) 0%, #4a0d1f 100%);
            border: 1px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 20px 25px;
            border-radius: 8px;
            margin-bottom: 30px;
        }
        .form-header h4 { margin: 0; font-size: 1.5rem; }
        .form-header i { margin-right: 10px; font-size: 1.8rem; }
        .form-header .estado-badge {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-left: 15px;
        }
        .estado-activo {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            border: 1px solid #28a745;
        }
        .estado-inactivo {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
            border: 1px solid #dc3545;
        }
        .info-box {
            background: rgba(197, 163, 103, 0.1);
            border-left: 4px solid var(--dorado-primario);
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 4px;
        }
        .info-box i { color: var(--dorado-primario); margin-right: 10px; }
        .form-group { margin-bottom: 25px; }
        .form-label {
            color: var(--dorado-primario);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95rem;
            text-transform: uppercase;
        }
        .form-label i { margin-right: 8px; }
        .form-control-custom, .form-select-custom {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 15px;
            border-radius: 6px;
        }
        .form-control-custom:focus, .form-select-custom:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            outline: none;
        }
        select.form-select-custom option {
            background: var(--vinotinto-sidebar);
            color: white;
        }
        .text-danger { font-size: 0.85rem; margin-top: 5px; display: block; color: #dc3545 !important; }
        .text-muted { color: rgba(255, 255, 255, 0.5) !important; font-size: 0.85rem; margin-top: 5px; }
        .btn-container {
            display: flex;
            justify-content: space-between;
            margin-top: 35px;
            padding-top: 20px;
            border-top: 2px solid rgba(197, 163, 103, 0.2);
        }
        .btn-secondary-custom {
            background: transparent;
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 30px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }
        .btn-secondary-custom:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            transform: translateY(-2px);
        }
        .btn-warning-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 12px 35px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .btn-warning-custom:hover {
            background: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
            transform: translateY(-2px);
        }
        .btn-warning-custom i, .btn-secondary-custom i { margin-right: 8px; }
        .validation-summary-errors {
            background: rgba(220, 53, 69, 0.1);
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 15px 20px;
            border-radius: 6px;
            margin-bottom: 25px;
        }
        .required-field::after {
            content: "*";
            color: #dc3545;
            margin-left: 4px;
            font-weight: bold;
        }
        .readonly-field {
            background: rgba(255, 255, 255, 0.02) !important;
            border: 1px solid rgba(197, 163, 103, 0.1) !important;
            color: rgba(255, 255, 255, 0.7) !important;
            cursor: not-allowed;
        }
    </style>
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-container">
                <div class="form-header">
                    <h4>
                        <i class="fas fa-edit me-2"></i>
                        Editar Cuenta #@Model.Id
                        @if (Model.EstadoId == 1)
                        {
                            <span class="estado-badge estado-activo">ACTIVA</span>
                        }
                        else
                        {
                            <span class="estado-badge estado-inactivo">INACTIVA</span>
                        }
                    </h4>
                </div>

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <strong>Cuenta:</strong> @ViewBag.CuentaInfo?.NumeroCuenta |
                    <strong>Cliente:</strong> @ViewBag.CuentaInfo?.ClienteNombre (@ViewBag.CuentaInfo?.ClienteIdentificacion) |
                    <strong>Saldo:</strong> ₡@ViewBag.CuentaInfo?.Saldo.ToString("N2")
                </div>

                <form asp-action="Edit" method="post" id="editForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-hashtag"></i> Número de Cuenta
                        </label>
                        <input type="text" class="form-control form-control-custom readonly-field"
                               value="@ViewBag.CuentaInfo?.NumeroCuenta" readonly disabled />
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-id-card"></i> Identificación del Cliente
                        </label>
                        <input type="text" class="form-control form-control-custom readonly-field"
                               value="@ViewBag.CuentaInfo?.ClienteIdentificacion" readonly disabled />
                        <small class="text-muted">No es posible cambiar el cliente dueño de la cuenta.</small>
                    </div>

                    <!-- Campo Tipo de Cuenta - CORREGIDO con selección basada en el modelo -->
                    <div class="form-group">
                        <label asp-for="TipoCuenta" class="form-label">
                            <i class="fas fa-tag"></i> Tipo de Cuenta <span class="required-field"></span>
                        </label>
                        <select asp-for="TipoCuenta" class="form-select form-select-custom" id="TipoCuenta" name="TipoCuenta">
                            <option value="">-- Seleccione un tipo --</option>
                            <option value="CORRIENTE" @(Model.TipoCuenta == "CORRIENTE" ? "selected" : "")>CORRIENTE</option>
                            <option value="AHORROS" @(Model.TipoCuenta == "AHORROS" ? "selected" : "")>AHORROS</option>
                        </select>
                        <span asp-validation-for="TipoCuenta" class="text-danger"></span>
                        <small class="text-muted">Seleccione el tipo de cuenta.</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="EstadoId" class="form-label">
                            <i class="fas fa-toggle-on"></i> Estado de la Cuenta
                        </label>
                        <select asp-for="EstadoId" class="form-select form-select-custom">
                            <option value="1">Activo - Cuenta habilitada para operaciones</option>
                            <option value="2">Inactivo - Cuenta bloqueada/deshabilitada</option>
                        </select>
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i> Las cuentas inactivas no pueden realizar operaciones.
                        </small>
                    </div>

                    <div class="btn-container">
                        <a asp-action="Index" class="btn-secondary-custom">
                            <i class="fas fa-arrow-left"></i> Regresar al Listado
                        </a>
                        <button type="submit" class="btn-warning-custom" id="btnActualizar">
                            <i class="fas fa-save"></i> Actualizar Cuenta
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            // Debug: Mostrar el valor actual del select
            console.log('Valor actual de TipoCuenta en el modelo:', '@Model.TipoCuenta');
            console.log('Valor seleccionado en el select:', $('#TipoCuenta').val());
            
            // Validación al enviar el formulario
            $('#editForm').on('submit', function(e) {
                e.preventDefault();
                
                var tipoCuenta = $('#TipoCuenta').val();
                var estadoId = $('#EstadoId').val();
                var errores = [];
                
                console.log('TipoCuenta seleccionado:', tipoCuenta);
                
                if (!tipoCuenta || tipoCuenta === '') {
                    errores.push('El tipo de cuenta es requerido');
                }
                
                if (errores.length > 0) {
                    Swal.fire({
                        title: 'Campos incompletos',
                        html: 'Por favor complete todos los campos requeridos:<br>• ' + errores.join('<br>• '),
                        icon: 'warning',
                        confirmButtonColor: '#c5a367',
                        background: '#1f060c',
                        color: '#fff'
                    });
                    return false;
                }
                
                // Mostrar loading
                Swal.fire({
                    title: 'Actualizando cuenta...',
                    text: 'Por favor espere',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
                
                var form = $(this);
                var url = form.attr('action');
                var data = form.serialize();
                
                console.log('Datos a enviar:', data);
                
                $.ajax({
                    url: url,
                    type: 'POST',
                    data: data,
                    success: function(response) {
                        if (response.success) {
                            Swal.fire({
                                title: '¡Éxito!',
                                text: response.message,
                                icon: 'success',
                                confirmButtonColor: '#c5a367',
                                background: '#1f060c',
                                color: '#fff'
                            }).then(() => {
                                window.location.href = '/CuentasCore/Index';
                            });
                        } else {
                            Swal.fire({
                                title: 'Error',
                                text: response.message,
                                icon: 'error',
                                confirmButtonColor: '#c5a367',
                                background: '#1f060c',
                                color: '#fff'
                            });
                        }
                    },
                    error: function(xhr) {
                        let errorMsg = 'Error al actualizar la cuenta';
                        try {
                            const response = JSON.parse(xhr.responseText);
                            if (response.message) errorMsg = response.message;
                        } catch(e) {
                            if (xhr.status === 500) {
                                errorMsg = 'Error interno del servidor. Por favor, intente nuevamente.';
                            } else if (xhr.status === 502 || xhr.status === 504) {
                                errorMsg = 'Error de conexión con el servidor.';
                            }
                        }
                        
                        Swal.fire({
                            title: 'Error de Operación',
                            text: errorMsg,
                            icon: 'error',
                            confirmButtonColor: '#c5a367',
                            background: '#1f060c',
                            color: '#fff'
                        });
                    }
                });
            });

            // Confirmar cambios antes de salir
            var formModified = false;
            $('input, select').on('change', function() { formModified = true; });
            $('input').on('keyup', function() { formModified = true; });

            $('a[asp-action="Index"]').click(function(e) {
                if (formModified) {
                    e.preventDefault();
                    Swal.fire({
                        title: '¿Salir sin guardar?',
                        text: 'Tiene cambios sin guardar. ¿Está seguro que desea salir?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#c5a367',
                        cancelButtonColor: '#dc3545',
                        confirmButtonText: '<i class="fas fa-sign-out-alt me-2"></i>Sí, salir',
                        cancelButtonText: '<i class="fas fa-times me-2"></i>Cancelar',
                        background: '#1f060c',
                        color: '#fff'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = $(this).attr('href');
                        }
                    });
                }
            });
        });
    </script>
}