@model Pegasos.Web.Administrador.Models.EditarCuentaCoreViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Editar Cuenta";
}

@section Styles {
    <style>
        .form-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid var(--dorado-primario);
            border-radius: 8px;
            padding: 30px;
            backdrop-filter: blur(5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .form-header {
            background: linear-gradient(135deg, var(--vinotinto-sidebar) 0%, #4a0d1f 100%);
            border: 1px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 20px 25px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .form-header h4 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 600;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        .form-header i {
            margin-right: 10px;
            color: var(--dorado-primario);
            font-size: 1.8rem;
        }

        .form-header .estado-badge {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-left: 15px;
        }

        .estado-activo {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            border: 1px solid #28a745;
        }

        .estado-inactivo {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
            border: 1px solid #dc3545;
        }

        .info-box {
            background: rgba(197, 163, 103, 0.1);
            border-left: 4px solid var(--dorado-primario);
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 4px;
        }

        .info-box i {
            color: var(--dorado-primario);
            margin-right: 10px;
            font-size: 1.2rem;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            color: var(--dorado-primario);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-label i {
            margin-right: 8px;
            color: var(--dorado-primario);
        }

        .form-control-custom, .form-select-custom {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 15px;
            border-radius: 6px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-control-custom:focus, .form-select-custom:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            box-shadow: 0 0 0 3px rgba(197, 163, 103, 0.1);
            outline: none;
        }

        .form-control-custom::placeholder {
            color: rgba(255, 255, 255, 0.5);
            font-style: italic;
        }

        select.form-select-custom option {
            background: var(--vinotinto-sidebar);
            color: white;
        }

        .text-danger {
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
            color: #dc3545 !important;
        }

        .text-muted {
            color: rgba(255, 255, 255, 0.5) !important;
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
        }

        .btn-container {
            display: flex;
            justify-content: space-between;
            margin-top: 35px;
            padding-top: 20px;
            border-top: 2px solid rgba(197, 163, 103, 0.2);
        }

        .btn-secondary-custom {
            background: transparent;
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 30px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-secondary-custom:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            transform: translateY(-2px);
        }

        .btn-warning-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 12px 35px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .btn-warning-custom:hover {
            background: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(197, 163, 103, 0.3);
        }

        .btn-warning-custom i, .btn-secondary-custom i {
            margin-right: 8px;
        }

        .validation-summary-errors {
            background: rgba(220, 53, 69, 0.1);
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 15px 20px;
            border-radius: 6px;
            margin-bottom: 25px;
        }

        .required-field::after {
            content: "*";
            color: #dc3545;
            margin-left: 4px;
            font-weight: bold;
        }

        .readonly-field {
            background: rgba(255, 255, 255, 0.02) !important;
            border: 1px solid rgba(197, 163, 103, 0.1) !important;
            color: rgba(255, 255, 255, 0.7) !important;
            cursor: not-allowed;
        }

        /* Estilos para SweetAlert2 */
        .custom-success-modal .swal2-popup {
            background: linear-gradient(135deg, #1f060c 0%, #2a0a14 100%);
            border: 2px solid #c5a367;
            border-radius: 15px;
            color: white;
        }

        .custom-success-modal .swal2-title {
            color: #c5a367;
            font-size: 1.8rem;
        }

        .custom-success-modal .swal2-html-container {
            color: #ffffff;
            font-size: 1.1rem;
        }

        .custom-success-modal .swal2-confirm {
            background: transparent !important;
            border: 2px solid #c5a367 !important;
            color: #c5a367 !important;
            border-radius: 8px !important;
            padding: 10px 30px !important;
            font-weight: 600 !important;
            transition: all 0.3s ease !important;
        }

        .custom-success-modal .swal2-confirm:hover {
            background: #c5a367 !important;
            color: #1f060c !important;
            transform: translateY(-2px);
        }

        .custom-modal .swal2-popup {
            background: linear-gradient(135deg, #1f060c 0%, #2a0a14 100%);
            border: 2px solid #c5a367;
            border-radius: 15px;
            color: white;
        }

        .custom-modal .swal2-title {
            color: #c5a367;
        }

        .custom-modal .swal2-html-container {
            color: #ffffff;
        }
    </style>
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-container">
                <div class="form-header">
                    <h4>
                        <i class="fas fa-edit me-2"></i>
                        Editar Cuenta #@Model.Id
                        @if (Model.EstadoId == 1)
                        {
                            <span class="estado-badge estado-activo">ACTIVA</span>
                        }
                        else
                        {
                            <span class="estado-badge estado-inactivo">INACTIVA</span>
                        }
                    </h4>
                </div>

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <strong>Cuenta:</strong> @ViewBag.CuentaInfo?.NumeroCuenta |
                    <strong>Cliente:</strong> @ViewBag.CuentaInfo?.ClienteNombre (@ViewBag.CuentaInfo?.ClienteIdentificacion) |
                    <strong>Saldo:</strong> ₡@ViewBag.CuentaInfo?.Saldo.ToString("N2")
                </div>

                <form asp-action="Edit" method="post" id="editForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-hashtag"></i> Número de Cuenta
                        </label>
                        <input type="text" class="form-control form-control-custom readonly-field"
                               value="@ViewBag.CuentaInfo?.NumeroCuenta" readonly disabled />
                    </div>

                    <div class="form-group">
                        <label class="form-label">
                            <i class="fas fa-id-card"></i> Identificación del Cliente
                        </label>
                        <input type="text" class="form-control form-control-custom readonly-field"
                               value="@ViewBag.CuentaInfo?.ClienteIdentificacion" readonly disabled />
                        <small class="text-muted">No es posible cambiar el cliente dueño de la cuenta.</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="TipoCuenta" class="form-label">
                            <i class="fas fa-tag"></i> Tipo de Cuenta <span class="required-field"></span>
                        </label>
                        <select asp-for="TipoCuenta" class="form-select form-select-custom" id="TipoCuenta" name="TipoCuenta">
                            <option value="">-- Seleccione un tipo --</option>
                            <option value="CORRIENTE" @(Model.TipoCuenta == "CORRIENTE" ? "selected" : "")>CORRIENTE</option>
                            <option value="AHORROS" @(Model.TipoCuenta == "AHORROS" ? "selected" : "")>AHORROS</option>
                        </select>
                        <span asp-validation-for="TipoCuenta" class="text-danger"></span>
                        <small class="text-muted">Seleccione el tipo de cuenta.</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="EstadoId" class="form-label">
                            <i class="fas fa-toggle-on"></i> Estado de la Cuenta
                        </label>
                        <select asp-for="EstadoId" class="form-select form-select-custom">
                            <option value="1">Activo - Cuenta habilitada para operaciones</option>
                            <option value="2">Inactivo - Cuenta bloqueada/deshabilitada</option>
                        </select>
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i> Las cuentas inactivas no pueden realizar operaciones.
                        </small>
                    </div>

                    <div class="btn-container">
                        <a asp-action="Index" class="btn-secondary-custom" id="btnRegresar">
                            <i class="fas fa-arrow-left"></i> Regresar al Listado
                        </a>
                        <button type="submit" class="btn-warning-custom" id="btnActualizar">
                            <i class="fas fa-save"></i> Actualizar Cuenta
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            var formModified = false;

            $('#TipoCuenta').on('change', function() {
                formModified = true;
            });

            $('#EstadoId').on('change', function() {
                formModified = true;
            });

            // Envío del formulario con AJAX y modal de éxito
            $('#editForm').on('submit', function(e) {
                e.preventDefault();

                var tipoCuenta = $('#TipoCuenta').val();
                var errores = [];

                if (!tipoCuenta || tipoCuenta === '') {
                    errores.push('El tipo de cuenta es requerido');
                }

                if (errores.length > 0) {
                    Swal.fire({
                        title: 'Campos incompletos',
                        html: 'Por favor complete todos los campos requeridos:<br>• ' + errores.join('<br>• '),
                        icon: 'warning',
                        confirmButtonColor: '#c5a367',
                        background: '#1f060c',
                        color: '#fff',
                        customClass: { popup: 'custom-modal' }
                    });
                    return false;
                }

                // Mostrar loading
                var $btn = $('#btnActualizar');
                var textoOriginal = $btn.html();
                $btn.html('<i class="fas fa-spinner fa-spin me-2"></i>Actualizando...').prop('disabled', true);

                var form = $(this);
                var url = form.attr('action');
                var data = form.serialize();

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: data,
                    success: function(response) {
                        if (response.success) {
                            Swal.fire({
                                title: '<i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i><br>¡Operación Exitosa!',
                                html: `
                                    <div style="padding: 10px;">
                                        <p style="font-size: 1.1rem; margin-bottom: 15px;">${response.message || 'Cuenta actualizada exitosamente'}</p>
                                        <div style="background: rgba(40, 167, 69, 0.1); border-radius: 8px; padding: 12px; margin-top: 10px;">
                                            <i class="fas fa-credit-card" style="color: #c5a367; margin-right: 8px;"></i>
                                            <strong style="color: #c5a367;">Cuenta actualizada correctamente</strong>
                                        </div>
                                    </div>
                                `,
                                icon: 'success',
                                confirmButtonText: '<i class="fas fa-arrow-right me-2"></i>Ir al Listado',
                                confirmButtonColor: '#c5a367',
                                background: '#1f060c',
                                color: '#fff',
                                customClass: { popup: 'custom-success-modal' },
                                allowOutsideClick: false
                            }).then(() => {
                                window.location.href = '/CuentasCore/Index';
                            });
                        } else {
                            $btn.html(textoOriginal).prop('disabled', false);
                            Swal.fire({
                                title: 'Error',
                                text: response.message || 'Error al actualizar la cuenta',
                                icon: 'error',
                                confirmButtonColor: '#c5a367',
                                background: '#1f060c',
                                color: '#fff',
                                customClass: { popup: 'custom-modal' }
                            });
                        }
                    },
                    error: function(xhr) {
                        $btn.html(textoOriginal).prop('disabled', false);
                        let errorMsg = 'Error al actualizar la cuenta';
                        try {
                            const response = JSON.parse(xhr.responseText);
                            if (response.message) errorMsg = response.message;
                        } catch(e) {
                            if (xhr.status === 500) errorMsg = 'Error interno del servidor';
                        }
                        Swal.fire({
                            title: 'Error',
                            text: errorMsg,
                            icon: 'error',
                            confirmButtonColor: '#c5a367',
                            background: '#1f060c',
                            color: '#fff',
                            customClass: { popup: 'custom-modal' }
                        });
                    }
                });
            });

            // Confirmar cambios antes de salir
            $('#btnRegresar').click(function(e) {
                if (formModified) {
                    e.preventDefault();
                    Swal.fire({
                        title: '¿Salir sin guardar?',
                        text: 'Tiene cambios sin guardar. ¿Está seguro que desea salir?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#c5a367',
                        cancelButtonColor: '#dc3545',
                        confirmButtonText: '<i class="fas fa-sign-out-alt me-2"></i>Sí, salir',
                        cancelButtonText: '<i class="fas fa-times me-2"></i>Cancelar',
                        background: '#1f060c',
                        color: '#fff',
                        customClass: { popup: 'custom-modal' }
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '/CuentasCore/Index';
                        }
                    });
                }
            });
        });
    </script>
}