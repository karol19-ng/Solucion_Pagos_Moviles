@model Pegasos.Web.Administrador.Models.CuentaCoreViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Detalles de Cuenta";
}

@section Styles {
    <style>
        .detail-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid var(--dorado-primario);
            border-radius: 8px;
            padding: 30px;
            backdrop-filter: blur(5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .detail-header {
            background: linear-gradient(135deg, var(--vinotinto-sidebar) 0%, #4a0d1f 100%);
            border: 1px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 20px 25px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

            .detail-header h4 {
                margin: 0;
                font-size: 1.5rem;
                font-weight: 600;
                text-shadow: 0 2px 4px rgba(0,0,0,0.3);
            }

            .detail-header i {
                margin-right: 10px;
                color: var(--dorado-primario);
                font-size: 1.8rem;
            }

        .info-card {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(197, 163, 103, 0.2);
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .info-row {
            display: flex;
            margin-bottom: 15px;
            border-bottom: 1px solid rgba(197, 163, 103, 0.1);
            padding-bottom: 10px;
        }

        .info-label {
            width: 200px;
            color: var(--dorado-primario);
            font-weight: 600;
        }

        .info-value {
            flex: 1;
            color: white;
        }

        .badge-success {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid #28a745;
        }

        .badge-danger {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid #dc3545;
        }

        .btn-primary-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 10px 25px;
            border-radius: 6px;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

            .btn-primary-custom:hover {
                background: var(--dorado-primario);
                color: var(--vinotinto-sidebar);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(197, 163, 103, 0.3);
            }

            .btn-primary-custom i {
                margin-right: 8px;
            }

        .btn-secondary-custom {
            background: transparent;
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 10px 25px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

            .btn-secondary-custom:hover {
                background: rgba(255, 255, 255, 0.1);
                border-color: var(--dorado-primario);
                color: white;
                transform: translateY(-2px);
            }

        .btn-warning-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 10px 25px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

            .btn-warning-custom:hover {
                background: var(--dorado-primario);
                color: var(--vinotinto-sidebar);
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(197, 163, 103, 0.3);
            }

        .action-buttons {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 20px;
        }

        .estado-badge-large {
            display: inline-block;
            padding: 8px 20px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 1rem;
        }
    </style>
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="detail-container">
                <div class="detail-header d-flex justify-content-between align-items-center">
                    <h4>
                        <i class="fas fa-credit-card"></i>
                        Detalles de la Cuenta
                    </h4>
                    <div>
                        @if (Model.EstadoId == 1)
                        {
                            <span class="estado-badge-large badge-success">ACTIVA</span>
                        }
                        else
                        {
                            <span class="estado-badge-large badge-danger">INACTIVA</span>
                        }
                    </div>
                </div>

                <div class="info-card">
                    <h5 style="color: var(--dorado-primario); margin-bottom: 20px;">
                        <i class="fas fa-info-circle me-2"></i>Información de la Cuenta
                    </h5>

                    <div class="info-row">
                        <div class="info-label">ID de Cuenta:</div>
                        <div class="info-value">#@Model.Id</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Número de Cuenta:</div>
                        <div class="info-value"><strong>@Model.NumeroCuenta</strong></div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Tipo de Cuenta:</div>
                        <div class="info-value">@Model.TipoCuenta</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Saldo Actual:</div>
                        <div class="info-value">
                            <span style="font-size: 1.3rem; font-weight: bold; color: var(--dorado-primario);">
                                ₡@Model.Saldo.ToString("N2")
                            </span>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Fecha de Apertura:</div>
                        <div class="info-value">@Model.FechaApertura.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                </div>

                <div class="info-card">
                    <h5 style="color: var(--dorado-primario); margin-bottom: 20px;">
                        <i class="fas fa-user me-2"></i>Información del Cliente
                    </h5>

                    <div class="info-row">
                        <div class="info-label">Cliente ID:</div>
                        <div class="info-value">#@Model.ClienteId</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Nombre Completo:</div>
                        <div class="info-value">@Model.ClienteNombre</div>
                    </div>

                    <div class="info-row">
                        <div class="info-label">Identificación:</div>
                        <div class="info-value">@Model.ClienteIdentificacion</div>
                    </div>
                </div>

                <div class="action-buttons">
                    <a asp-action="Index" class="btn-secondary-custom">
                        <i class="fas fa-arrow-left"></i> Regresar
                    </a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-warning-custom">
                        <i class="fas fa-edit"></i> Editar Cuenta
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>