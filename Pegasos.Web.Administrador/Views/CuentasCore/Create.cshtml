@model Pegasos.Web.Administrador.Models.CrearCuentaCoreViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Crear Nueva Cuenta";
}

@section Styles {
    <style>
        .form-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid var(--dorado-primario);
            border-radius: 8px;
            padding: 30px;
            backdrop-filter: blur(5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .form-header {
            background: linear-gradient(135deg, var(--vinotinto-sidebar) 0%, #4a0d1f 100%);
            border: 1px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 20px 25px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .form-header h4 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 600;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        .form-header i {
            margin-right: 10px;
            color: var(--dorado-primario);
            font-size: 1.8rem;
        }

        .info-box {
            background: rgba(197, 163, 103, 0.1);
            border-left: 4px solid var(--dorado-primario);
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 4px;
        }

        .info-box i {
            color: var(--dorado-primario);
            margin-right: 10px;
            font-size: 1.2rem;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            color: var(--dorado-primario);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-label i {
            margin-right: 8px;
            color: var(--dorado-primario);
        }

        .form-control-custom, .form-select-custom {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 15px;
            border-radius: 6px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-control-custom:focus, .form-select-custom:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            box-shadow: 0 0 0 3px rgba(197, 163, 103, 0.1);
            outline: none;
        }

        .form-control-custom::placeholder {
            color: rgba(255, 255, 255, 0.5);
            font-style: italic;
        }

        select.form-select-custom option {
            background: var(--vinotinto-sidebar);
            color: white;
        }

        .text-danger {
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
            color: #dc3545 !important;
        }

        .text-muted {
            color: rgba(255, 255, 255, 0.5) !important;
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
        }

        .btn-container {
            display: flex;
            justify-content: space-between;
            margin-top: 35px;
            padding-top: 20px;
            border-top: 2px solid rgba(197, 163, 103, 0.2);
        }

        .btn-secondary-custom {
            background: transparent;
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 30px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-secondary-custom:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            transform: translateY(-2px);
        }

        .btn-primary-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 12px 35px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .btn-primary-custom:hover {
            background: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(197, 163, 103, 0.3);
        }

        .btn-primary-custom i, .btn-secondary-custom i {
            margin-right: 8px;
        }

        .validation-summary-errors {
            background: rgba(220, 53, 69, 0.1);
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 15px 20px;
            border-radius: 6px;
            margin-bottom: 25px;
        }

        .required-field::after {
            content: "*";
            color: #dc3545;
            margin-left: 4px;
            font-weight: bold;
        }

        .id-examples {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }

        .id-example-tag {
            background: rgba(197, 163, 103, 0.15);
            border: 1px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .id-example-tag:hover {
            background: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
            transform: translateY(-2px);
        }

        .cliente-info-card {
            background: rgba(40, 167, 69, 0.1);
            border: 1px solid #28a745;
            border-radius: 8px;
            padding: 15px 20px;
            margin-top: 15px;
            display: none;
            animation: fadeInUp 0.3s ease-out;
        }

        .cliente-info-card i {
            color: #28a745;
            margin-right: 10px;
        }

        .cliente-info-content {
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .cliente-badge {
            background: #28a745;
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .validation-spinner {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            width: 20px;
            height: 20px;
            border: 2px solid rgba(197, 163, 103, 0.3);
            border-radius: 50%;
            border-top-color: var(--dorado-primario);
            animation: spin 1s linear infinite;
            display: none;
        }

        .input-wrapper {
            position: relative;
        }

        .validation-message {
            display: block;
            margin-top: 8px;
            font-size: 0.85rem;
            padding-left: 16px;
        }

        .validation-success {
            color: #28a745 !important;
        }

        .validation-success i {
            color: #28a745;
            margin-right: 5px;
        }

        .validation-error {
            color: #dc3545 !important;
        }

        .validation-error i {
            color: #dc3545;
            margin-right: 5px;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Estilos para SweetAlert2 */
        .custom-success-modal .swal2-popup {
            background: linear-gradient(135deg, #1f060c 0%, #2a0a14 100%);
            border: 2px solid #c5a367;
            border-radius: 15px;
            color: white;
        }

        .custom-success-modal .swal2-title {
            color: #c5a367;
            font-size: 1.8rem;
        }

        .custom-success-modal .swal2-html-container {
            color: #ffffff;
            font-size: 1.1rem;
        }

        .custom-success-modal .swal2-confirm {
            background: transparent !important;
            border: 2px solid #c5a367 !important;
            color: #c5a367 !important;
            border-radius: 8px !important;
            padding: 10px 30px !important;
            font-weight: 600 !important;
            transition: all 0.3s ease !important;
        }

        .custom-success-modal .swal2-confirm:hover {
            background: #c5a367 !important;
            color: #1f060c !important;
            transform: translateY(-2px);
        }

        .custom-modal .swal2-popup {
            background: linear-gradient(135deg, #1f060c 0%, #2a0a14 100%);
            border: 2px solid #c5a367;
            border-radius: 15px;
            color: white;
        }

        .custom-modal .swal2-title {
            color: #c5a367;
        }

        .custom-modal .swal2-html-container {
            color: #ffffff;
        }
    </style>
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-container">
                <div class="form-header">
                    <h4>
                        <i class="fas fa-credit-card"></i>
                        Crear Nueva Cuenta
                    </h4>
                </div>

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <strong>Información:</strong> Complete los datos para crear una nueva cuenta. El número de cuenta se generará automáticamente.
                </div>

                <form asp-action="Create" method="post" id="createForm">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <!-- Campo Identificación del Cliente -->
                    <div class="form-group">
                        <label asp-for="ClienteIdentificacion" class="form-label">
                            <i class="fas fa-id-card"></i> Identificación del Cliente <span class="required-field"></span>
                        </label>
                        <div class="input-wrapper">
                            <input asp-for="ClienteIdentificacion" class="form-control form-control-custom"
                                   id="ClienteIdentificacion" name="ClienteIdentificacion"
                                   placeholder="Ej: 100, 109990888, 305550444"
                                   value="@Model?.ClienteIdentificacion" 
                                   autocomplete="off" />
                            <div class="validation-spinner" id="validacionSpinner"></div>
                        </div>

                        <!-- Ejemplos rápidos -->
                        <div class="id-examples">
                            <span class="id-example-tag" onclick="setClienteValue('100')">ID: 100</span>
                            <span class="id-example-tag" onclick="setClienteValue('101')">ID: 101</span>
                            <span class="id-example-tag" onclick="setClienteValue('102')">ID: 102</span>
                            <span class="id-example-tag" onclick="setClienteValue('103')">ID: 103</span>
                            <span class="id-example-tag" onclick="setClienteValue('109990888')">ID: 109990888</span>
                            <span class="id-example-tag" onclick="setClienteValue('305550444')">ID: 305550444</span>
                        </div>

                        <span class="validation-message" id="clienteIdentificacionError"></span>

                        <!-- Tarjeta de información del cliente -->
                        <div id="clienteInfo" class="cliente-info-card">
                            <div class="cliente-info-content">
                                <i class="fas fa-check-circle fa-2x"></i>
                                <div style="flex: 1;">
                                    <strong style="color: #28a745;">Cliente validado</strong>
                                    <div id="clienteInfoText" style="color: white; margin-top: 5px;"></div>
                                </div>
                                <span class="cliente-badge">✓ Verificado</span>
                            </div>
                        </div>

                        <div class="help-text" style="color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 8px;">
                            <i class="fas fa-lightbulb"></i>
                            Puede usar ID numérico (100, 101, 102, 103) o la identificación real del cliente
                        </div>
                    </div>

                    <!-- Campo Tipo de Cuenta -->
                    <div class="form-group">
                        <label asp-for="TipoCuenta" class="form-label">
                            <i class="fas fa-tag"></i> Tipo de Cuenta <span class="required-field"></span>
                        </label>
                        <select asp-for="TipoCuenta" class="form-select form-select-custom" id="TipoCuenta">
                            <option value="">-- Seleccione un tipo --</option>
                            <option value="CORRIENTE">CORRIENTE</option>
                            <option value="AHORROS">AHORROS</option>
                        </select>
                        <span asp-validation-for="TipoCuenta" class="text-danger"></span>
                        <div class="help-text" style="color: rgba(255,255,255,0.5); font-size: 0.85rem; margin-top: 8px;">
                            <i class="fas fa-info-circle"></i>
                            Seleccione el tipo de cuenta que desea crear.
                        </div>
                    </div>

                    <div class="btn-container">
                        <a asp-action="Index" class="btn-secondary-custom">
                            <i class="fas fa-arrow-left"></i> Regresar al Listado
                        </a>
                        <button type="submit" class="btn-primary-custom" id="btnGuardar" disabled>
                            <i class="fas fa-save"></i> Guardar Cuenta
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let clienteValidado = false;
        let clienteNombre = '';
        let timeoutId;

        // Función para autocompletar con ejemplos
        window.setClienteValue = function(valor) {
            $('#ClienteIdentificacion').val(valor).trigger('input');
        }

        $(document).ready(function() {
            // Validación en tiempo real para identificación
            $('#ClienteIdentificacion').on('input', function() {
                clearTimeout(timeoutId);
                var valor = $(this).val();
                
                $('#clienteIdentificacionError').removeClass('validation-success validation-error');
                
                if (!valor || valor.trim() === '') {
                    $('#clienteIdentificacionError').html('<i class="fas fa-exclamation-circle"></i> La identificación del cliente es requerida')
                        .addClass('validation-error');
                    $('#clienteInfo').hide();
                    $('#btnGuardar').prop('disabled', true);
                    clienteValidado = false;
                    $('#validacionSpinner').hide();
                    return;
                }
                
                $('#validacionSpinner').show();
                $('#clienteIdentificacionError').html('<i class="fas fa-spinner fa-spin"></i> Validando cliente...');
                
                timeoutId = setTimeout(function() {
                    validarCliente(valor);
                }, 300);
            });

            // Validación del tipo de cuenta
            $('#TipoCuenta').on('change', function() {
                habilitarBotonGuardar();
            });

            function validarCliente(valor) {
                $.ajax({
                    url: '/CuentasCore/ValidarCliente',
                    type: 'GET',
                    data: { valor: valor },
                    success: function(response) {
                        $('#validacionSpinner').hide();
                        
                        if (response.existe) {
                            $('#clienteIdentificacionError')
                                .html('<i class="fas fa-check-circle"></i> ' + response.mensaje)
                                .removeClass('validation-error')
                                .addClass('validation-success');
                            
                            clienteNombre = response.cliente.nombreCompleto;
                            $('#clienteInfoText').html(`
                                <strong>${response.cliente.nombreCompleto}</strong><br>
                                <small>ID: ${response.cliente.id} | Identificación: ${response.cliente.identificacion}</small>
                            `);
                            $('#clienteInfo').show();
                            clienteValidado = true;
                        } else {
                            $('#clienteIdentificacionError')
                                .html('<i class="fas fa-exclamation-circle"></i> ' + response.mensaje)
                                .removeClass('validation-success')
                                .addClass('validation-error');
                            $('#clienteInfo').hide();
                            clienteValidado = false;
                        }
                        habilitarBotonGuardar();
                    },
                    error: function() {
                        $('#validacionSpinner').hide();
                        $('#clienteIdentificacionError')
                            .html('<i class="fas fa-exclamation-circle"></i> Error al validar el cliente')
                            .removeClass('validation-success')
                            .addClass('validation-error');
                        $('#clienteInfo').hide();
                        clienteValidado = false;
                        habilitarBotonGuardar();
                    }
                });
            }

            function habilitarBotonGuardar() {
                var tipoCuentaValido = $('#TipoCuenta').val() && $('#TipoCuenta').val() !== '';
                $('#btnGuardar').prop('disabled', !(clienteValidado && tipoCuentaValido));
            }

            // Envío del formulario con AJAX y modal de éxito
            $('#createForm').on('submit', function(e) {
                e.preventDefault();
                
                var identificacion = $('#ClienteIdentificacion').val();
                var tipoCuenta = $('#TipoCuenta').val();
                var errores = [];

                if (!clienteValidado) {
                    errores.push('Debe validar un cliente existente');
                }

                if (!tipoCuenta || tipoCuenta === '') {
                    errores.push('El tipo de cuenta es requerido');
                }

                if (errores.length > 0) {
                    Swal.fire({
                        title: 'Campos incompletos',
                        html: 'Por favor complete todos los campos requeridos:<br>• ' + errores.join('<br>• '),
                        icon: 'warning',
                        confirmButtonColor: '#c5a367',
                        background: '#1f060c',
                        color: '#fff',
                        customClass: { popup: 'custom-modal' }
                    });
                    return false;
                }

                // Mostrar loading en el botón
                var $btn = $('#btnGuardar');
                var textoOriginal = $btn.html();
                $btn.html('<i class="fas fa-spinner fa-spin me-2"></i>Creando cuenta...').prop('disabled', true);

                var formData = new FormData();
                formData.append('ClienteIdentificacion', identificacion);
                formData.append('TipoCuenta', tipoCuenta);
                formData.append('__RequestVerificationToken', $('input[name="__RequestVerificationToken"]').val());

                $.ajax({
                    url: '@Url.Action("Create", "CuentasCore")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function(response) {
                        if (response.success) {
                            Swal.fire({
                                title: '<i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i><br>¡Operación Exitosa!',
                                html: `
                                    <div style="padding: 10px;">
                                        <p style="font-size: 1.1rem; margin-bottom: 15px;">${response.message}</p>
                                        <div style="background: rgba(40, 167, 69, 0.1); border-radius: 8px; padding: 12px; margin-top: 10px;">
                                            <i class="fas fa-credit-card" style="color: #c5a367; margin-right: 8px;"></i>
                                            <strong style="color: #c5a367;">Cuenta creada exitosamente</strong><br>
                                            <strong style="color: #c5a367;">Cliente: ${clienteNombre}</strong>
                                        </div>
                                    </div>
                                `,
                                icon: 'success',
                                confirmButtonText: '<i class="fas fa-arrow-right me-2"></i>Ir al Listado',
                                confirmButtonColor: '#c5a367',
                                background: '#1f060c',
                                color: '#fff',
                                customClass: { popup: 'custom-success-modal' },
                                allowOutsideClick: false
                            }).then(() => {
                                window.location.href = '/CuentasCore/Index';
                            });
                        } else {
                            $btn.html(textoOriginal).prop('disabled', false);
                            Swal.fire({
                                title: 'Error',
                                text: response.message,
                                icon: 'error',
                                confirmButtonColor: '#c5a367',
                                background: '#1f060c',
                                color: '#fff',
                                customClass: { popup: 'custom-modal' }
                            });
                        }
                    },
                    error: function(xhr) {
                        $btn.html(textoOriginal).prop('disabled', false);
                        let errorMsg = 'Error al crear la cuenta';
                        try {
                            const response = JSON.parse(xhr.responseText);
                            if (response.message) errorMsg = response.message;
                        } catch(e) {
                            if (xhr.status === 409) errorMsg = 'El cliente ya tiene una cuenta de este tipo';
                            else if (xhr.status === 500) errorMsg = 'Error interno del servidor';
                        }
                        Swal.fire({
                            title: 'Error',
                            text: errorMsg,
                            icon: 'error',
                            confirmButtonColor: '#c5a367',
                            background: '#1f060c',
                            color: '#fff',
                            customClass: { popup: 'custom-modal' }
                        });
                    }
                });
            });

            // Si ya hay un valor en el campo al cargar la página, validarlo
            var valorInicial = $('#ClienteIdentificacion').val();
            if (valorInicial && valorInicial.trim() !== '') {
                validarCliente(valorInicial);
            }
        });
    </script>
}