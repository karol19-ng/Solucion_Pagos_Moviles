@model Pegasos.Web.Administrador.Models.BitacoraViewModel

@{
    ViewData["Title"] = "Consulta de Bitacora";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4 mt-3">
        <div>
            <h2 style="font-family: 'Cinzel', serif; color: var(--dorado-primario); text-shadow: 2px 2px 4px rgba(0,0,0,0.5);">
                <i class="fas fa-journal-whills me-2"></i>CONSULTA DE BITACORA
            </h2>
            <p class="text-muted small">Registro de transacciones - Pegasos Bank</p>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>@ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (ViewBag.Debug != null)
    {
        <div class="alert alert-warning">@ViewBag.Debug</div>
    }

    <div class="card mb-4" style="background: rgba(31, 6, 12, 0.6); border: 1px solid var(--dorado-primario);">
        <div class="card-body">
            <form asp-action="Index" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small text-warning">
                            <i class="fas fa-calendar-alt me-1"></i>Digite la fecha
                        </label>
                        <input type="date" id="FechaInput" class="form-control bg-dark text-white border-secondary"
                               onchange="document.getElementById('FechaHidden').value = this.value" />
                        <input type="hidden" name="Fecha" id="FechaHidden" />
                    </div>
                    <div class="col-md-2 d-grid">
                        <button type="submit" class="btn fw-bold" style="background: var(--dorado-primario); color: #1f060c; border-radius: 0;">
                            <i class="fas fa-search me-1"></i>BUSCAR
                        </button>
                    </div>
                    <div class="col-md-2 d-grid">
                        <a asp-action="Index" class="btn btn-outline-secondary">LIMPIAR</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-lg" style="border-radius: 8px; overflow: hidden;">
        <table class="table table-hover align-middle" style="background-color: #1f060c; color: white; margin-bottom: 0;">
            <thead style="background: linear-gradient(90deg, #2d0a12 0%, #1f060c 100%); border-bottom: 2px solid var(--dorado-primario);">
                <tr class="text-warning small text-uppercase">
                    <th class="ps-4">Fecha</th>
                    <th>Telefono Origen</th>
                    <th>Telefono Destino</th>
                    <th class="text-end pe-4">Monto</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Resultados != null && Model.Resultados.Any())
                {
                    foreach (var item in Model.Resultados)
                    {
                        <tr style="border-bottom: 1px solid rgba(197, 163, 103, 0.1); transition: 0.2s;">
                            <td class="ps-4"><span style="color: #eee;">@item.Fecha.ToString("dd/MM/yyyy")</span></td>
                            <td><code class="text-warning">@item.TelefonoOrigen</code></td>
                            <td><code class="text-warning">@item.TelefonoDestino</code></td>
                            <td class="text-end pe-4">
                                <span class="fw-bold" style="color: var(--dorado-primario);">@item.Monto.ToString("N2")</span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">
                            <i class="fas fa-calendar-times fa-3x mb-3 d-block text-warning opacity-50"></i>
                            Digite una fecha para consultar las transacciones.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.Resultados != null && Model.Resultados.Any())
    {
        <div class="mt-2 text-end">
            <small class="text-muted">
                Total de registros: <span class="text-warning fw-bold">@Model.Resultados.Count</span>
            </small>
        </div>
    }
</div>
