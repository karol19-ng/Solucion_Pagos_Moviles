@model Pegasos.Web.Administrador.Models.EditarParametroViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Editar Parámetro";
}

@section Styles {
    <style>
        .form-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid var(--dorado-primario);
            border-radius: 8px;
            padding: 30px;
            backdrop-filter: blur(5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .form-header {
            background: linear-gradient(135deg, var(--vinotinto-sidebar) 0%, #4a0d1f 100%);
            border: 1px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 20px 25px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .form-header h4 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 600;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        .form-header i {
            margin-right: 10px;
            color: var(--dorado-primario);
            font-size: 1.8rem;
        }

        .form-header .estado-badge {
            display: inline-block;
            padding: 5px 15px;
            border-radius: 4px;
            font-size: 0.85rem;
            font-weight: 600;
            margin-left: 15px;
        }

        .estado-activo {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            border: 1px solid #28a745;
        }

        .estado-inactivo {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
            border: 1px solid #dc3545;
        }

        .info-box {
            background: rgba(197, 163, 103, 0.1);
            border-left: 4px solid var(--dorado-primario);
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 4px;
        }

        .info-box i {
            color: var(--dorado-primario);
            margin-right: 10px;
            font-size: 1.2rem;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            color: var(--dorado-primario);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-label i {
            margin-right: 8px;
            color: var(--dorado-primario);
        }

        .form-control-custom, .form-select-custom {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 15px;
            border-radius: 6px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-control-custom:focus, .form-select-custom:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            box-shadow: 0 0 0 3px rgba(197, 163, 103, 0.1);
            outline: none;
        }

        .form-control-custom::placeholder {
            color: rgba(255, 255, 255, 0.5);
            font-style: italic;
        }

        select.form-select-custom option {
            background: var(--vinotinto-sidebar);
            color: white;
        }

        .text-danger {
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
            color: #dc3545 !important;
        }

        .text-muted {
            color: rgba(255, 255, 255, 0.5) !important;
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
        }

        .btn-container {
            display: flex;
            justify-content: space-between;
            margin-top: 35px;
            padding-top: 20px;
            border-top: 2px solid rgba(197, 163, 103, 0.2);
        }

        .btn-secondary-custom {
            background: transparent;
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 30px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-secondary-custom:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            transform: translateY(-2px);
        }

        .btn-warning-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 12px 35px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .btn-warning-custom:hover {
            background: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(197, 163, 103, 0.3);
        }

        .btn-warning-custom i, .btn-secondary-custom i {
            margin-right: 8px;
        }

        .validation-summary-errors {
            background: rgba(220, 53, 69, 0.1);
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 15px 20px;
            border-radius: 6px;
            margin-bottom: 25px;
        }

        .required-field::after {
            content: "*";
            color: #dc3545;
            margin-left: 4px;
            font-weight: bold;
        }

        .readonly-field {
            background: rgba(255, 255, 255, 0.02) !important;
            border: 1px solid rgba(197, 163, 103, 0.1) !important;
            color: rgba(255, 255, 255, 0.7) !important;
            cursor: not-allowed;
        }

        /* Estilos para SweetAlert2 */
        .swal2-popup {
            font-size: 1rem !important;
            border: 1px solid var(--dorado-primario) !important;
            background: linear-gradient(135deg, #1f060c 0%, #2a0a12 100%) !important;
        }

        .swal2-title {
            color: var(--dorado-primario) !important;
        }

        .swal2-html-container {
            color: rgba(255, 255, 255, 0.9) !important;
        }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 10000;
            display: none;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }

        .spinner-custom {
            width: 50px;
            height: 50px;
            border: 4px solid var(--dorado-primario);
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-container">
                <div class="form-header">
                    <h4>
                        <i class="fas fa-edit me-2"></i>
                        Editar Parámetro: @Model.Id
                        @if (Model.EstadoId == 1)
                        {
                            <span class="estado-badge estado-activo">ACTIVO</span>
                        }
                        else
                        {
                            <span class="estado-badge estado-inactivo">INACTIVO</span>
                        }
                    </h4>
                </div>

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <strong>Modo Edición:</strong> Está modificando los datos del parámetro.
                </div>

                <form asp-action="Edit" method="post" id="editForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="Id" class="form-label">
                            <i class="fas fa-hashtag"></i> ID del Parámetro <span class="required-field"></span>
                        </label>
                        <input asp-for="Id" class="form-control form-control-custom readonly-field"
                               readonly disabled placeholder="El ID no se puede modificar" />
                        <small class="text-muted">El ID del parámetro no se puede modificar.</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Valor" class="form-label">
                            <i class="fas fa-dollar-sign"></i> Valor <span class="required-field"></span>
                        </label>
                        <input asp-for="Valor" class="form-control form-control-custom"
                               id="Valor" name="Valor"
                               placeholder="Ej: 24, 0.02, 500000, 300" />
                        <span asp-validation-for="Valor" class="text-danger" id="valorError"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="EstadoId" class="form-label">
                            <i class="fas fa-toggle-on"></i> Estado
                        </label>
                        <select asp-for="EstadoId" class="form-select form-select-custom">
                            <option value="1">Activo</option>
                            <option value="0">Inactivo</option>
                        </select>
                    </div>

                    <div class="btn-container">
                        <a asp-action="Index" class="btn-secondary-custom" id="btnRegresar">
                            <i class="fas fa-arrow-left"></i> Regresar al Listado
                        </a>
                        <button type="submit" class="btn-warning-custom" id="btnActualizar">
                            <i class="fas fa-save"></i> Actualizar Parámetro
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="spinner-custom"></div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function showLoading() {
            $('#loadingOverlay').fadeIn(200);
        }

        function hideLoading() {
            $('#loadingOverlay').fadeOut(200);
        }

        $(document).ready(function() {
            var formModified = false;
            
            $('#Valor').on('input', function() {
                var valor = $(this).val();
                formModified = true;
                if (!valor || valor.trim() === '') {
                    $('#valorError').text('El valor es requerido');
                } else {
                    $('#valorError').text('');
                }
            });

            $('#EstadoId').on('change', function() {
                formModified = true;
            });

            // Envío normal del formulario (sin AJAX)
            $('#editForm').on('submit', function(e) {
                var valor = $('#Valor').val();
                
                if (!valor || valor.trim() === '') {
                    e.preventDefault();
                    Swal.fire({
                        title: 'Campo requerido',
                        text: 'El valor del parámetro es requerido',
                        icon: 'warning',
                        confirmButtonColor: '#c5a367',
                        background: '#1f060c',
                        color: '#fff'
                    });
                    return false;
                }
                
                showLoading();
                return true;
            });

            // Confirmar cambios antes de salir
            $('#btnRegresar').click(function(e) {
                if (formModified) {
                    e.preventDefault();
                    Swal.fire({
                        title: '¿Salir sin guardar?',
                        text: 'Tiene cambios sin guardar. ¿Está seguro que desea salir?',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#c5a367',
                        cancelButtonColor: '#dc3545',
                        confirmButtonText: '<i class="fas fa-sign-out-alt me-2"></i>Sí, salir',
                        cancelButtonText: '<i class="fas fa-times me-2"></i>Cancelar',
                        background: '#1f060c',
                        color: '#fff'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '/Parametros/Index';
                        }
                    });
                }
            });
        });
    </script>
}