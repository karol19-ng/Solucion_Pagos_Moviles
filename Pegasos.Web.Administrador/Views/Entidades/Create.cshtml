@model Pegasos.Web.Administrador.Models.CrearEntidadViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Crear Nueva Entidad";
}

@section Styles {
    <style>
        .form-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid var(--dorado-primario);
            border-radius: 8px;
            padding: 30px;
            backdrop-filter: blur(5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .form-header {
            background: linear-gradient(135deg, var(--vinotinto-sidebar) 0%, #4a0d1f 100%);
            border: 1px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 20px 25px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .form-header h4 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 600;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }

        .form-header i {
            margin-right: 10px;
            color: var(--dorado-primario);
            font-size: 1.8rem;
        }

        .info-box {
            background: rgba(197, 163, 103, 0.1);
            border-left: 4px solid var(--dorado-primario);
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 4px;
        }

        .info-box i {
            color: var(--dorado-primario);
            margin-right: 10px;
            font-size: 1.2rem;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            color: var(--dorado-primario);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-label i {
            margin-right: 8px;
            color: var(--dorado-primario);
        }

        .form-control-custom, .form-select-custom {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 15px;
            border-radius: 6px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-control-custom:focus, .form-select-custom:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            box-shadow: 0 0 0 3px rgba(197, 163, 103, 0.1);
            outline: none;
        }

        .form-control-custom::placeholder {
            color: rgba(255, 255, 255, 0.5);
            font-style: italic;
        }

        select.form-select-custom option {
            background: var(--vinotinto-sidebar);
            color: white;
        }

        .text-danger {
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
            color: #dc3545 !important;
        }

        .text-muted {
            color: rgba(255, 255, 255, 0.5) !important;
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
        }

        .btn-container {
            display: flex;
            justify-content: space-between;
            margin-top: 35px;
            padding-top: 20px;
            border-top: 2px solid rgba(197, 163, 103, 0.2);
        }

        .btn-secondary-custom {
            background: transparent;
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 30px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-secondary-custom:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--dorado-primario);
            color: white;
            transform: translateY(-2px);
        }

        .btn-primary-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 12px 35px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

        .btn-primary-custom:hover {
            background: var(--dorado-primario);
            color: var(--vinotinto-sidebar);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(197, 163, 103, 0.3);
        }

        .btn-primary-custom i, .btn-secondary-custom i {
            margin-right: 8px;
        }

        .validation-summary-errors {
            background: rgba(220, 53, 69, 0.1);
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 15px 20px;
            border-radius: 6px;
            margin-bottom: 25px;
        }

        .required-field::after {
            content: "*";
            color: #dc3545;
            margin-left: 4px;
            font-weight: bold;
        }

        /* Estilos para SweetAlert2 */
        .custom-success-modal .swal2-popup {
            background: linear-gradient(135deg, #1f060c 0%, #2a0a14 100%);
            border: 2px solid #c5a367;
            border-radius: 15px;
            color: white;
        }

        .custom-success-modal .swal2-title {
            color: #c5a367;
            font-size: 1.8rem;
        }

        .custom-success-modal .swal2-html-container {
            color: #ffffff;
            font-size: 1.1rem;
        }

        .custom-success-modal .swal2-confirm {
            background: transparent !important;
            border: 2px solid #c5a367 !important;
            color: #c5a367 !important;
            border-radius: 8px !important;
            padding: 10px 30px !important;
            font-weight: 600 !important;
            transition: all 0.3s ease !important;
        }

        .custom-success-modal .swal2-confirm:hover {
            background: #c5a367 !important;
            color: #1f060c !important;
            transform: translateY(-2px);
        }

        .custom-modal .swal2-popup {
            background: linear-gradient(135deg, #1f060c 0%, #2a0a14 100%);
            border: 2px solid #c5a367;
            border-radius: 15px;
            color: white;
        }

        .custom-modal .swal2-title {
            color: #c5a367;
        }

        .custom-modal .swal2-html-container {
            color: #ffffff;
        }
    </style>
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-container">
                <div class="form-header">
                    <h4>
                        <i class="fas fa-university"></i>
                        Crear Nueva Entidad Bancaria
                    </h4>
                </div>

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <strong>Información:</strong> Complete los datos para registrar una nueva entidad bancaria.
                </div>

                <form asp-action="Create" method="post" id="createForm">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="Identificador" class="form-label">
                            <i class="fas fa-hashtag"></i> Identificador <span class="required-field"></span>
                        </label>
                        <input asp-for="Identificador" class="form-control form-control-custom"
                               id="Identificador" name="Identificador"
                               placeholder="Ej: BCR, BN, BAC, etc."
                               value="@Model?.Identificador" />
                        <span asp-validation-for="Identificador" class="text-danger" id="identificadorError"></span>
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i> Código único de la entidad (ej: BCR, BN, BAC)
                        </small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Nombre" class="form-label">
                            <i class="fas fa-building"></i> Nombre de la Entidad <span class="required-field"></span>
                        </label>
                        <input asp-for="Nombre" class="form-control form-control-custom"
                               id="Nombre" name="Nombre"
                               placeholder="Ej: Banco de Costa Rica, Banco Nacional, etc." />
                        <span asp-validation-for="Nombre" class="text-danger" id="nombreError"></span>
                    </div>

                    <div class="btn-container">
                        <a asp-action="Index" class="btn-secondary-custom">
                            <i class="fas fa-arrow-left"></i> Regresar al Listado
                        </a>
                        <button type="submit" class="btn-primary-custom" id="btnGuardar">
                            <i class="fas fa-save"></i> Guardar Entidad
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            // Variable para evitar doble envío
            var isSubmitting = false;

            // Validación en tiempo real
            $('#Identificador').on('input', function() {
                var valor = $(this).val();
                if (!valor || valor.trim() === '') {
                    $('#identificadorError').text('El identificador es requerido');
                } else {
                    $('#identificadorError').text('');
                }
            });

            $('#Nombre').on('input', function() {
                var valor = $(this).val();
                if (!valor || valor.trim() === '') {
                    $('#nombreError').text('El nombre es requerido');
                } else {
                    $('#nombreError').text('');
                }
            });

            // Envío del formulario
            $('#createForm').on('submit', function(e) {
                e.preventDefault();
                
                if (isSubmitting) return false;
                
                var identificador = $('#Identificador').val();
                var nombre = $('#Nombre').val();
                var errores = [];

                if (!identificador || identificador.trim() === '') {
                    errores.push('El identificador es requerido');
                    $('#identificadorError').text('El identificador es requerido');
                }

                if (!nombre || nombre.trim() === '') {
                    errores.push('El nombre es requerido');
                    $('#nombreError').text('El nombre es requerido');
                }

                if (errores.length > 0) {
                    Swal.fire({
                        title: 'Campos incompletos',
                        html: '<div style="text-align: left;">Por favor complete todos los campos requeridos:<br>• ' + errores.join('<br>• ') + '</div>',
                        icon: 'warning',
                        confirmButtonColor: '#c5a367',
                        background: '#1f060c',
                        color: '#fff',
                        customClass: { popup: 'custom-modal' }
                    });
                    return false;
                }

                isSubmitting = true;

                // Mostrar loading
                var $btn = $('#btnGuardar');
                var textoOriginal = $btn.html();
                $btn.html('<i class="fas fa-spinner fa-spin me-2"></i>Guardando...').prop('disabled', true);

                var form = $(this);
                var url = form.attr('action');
                var data = form.serialize();

                $.ajax({
                    url: url,
                    type: 'POST',
                    data: data,
                    dataType: 'json', // Importante: esperar JSON
                    success: function(response) {
                        isSubmitting = false;
                        
                        // Verificar si la respuesta es un objeto JSON con success
                        if (response && typeof response === 'object') {
                            if (response.success) {
                                Swal.fire({
                                    title: '<i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i><br>¡Operación Exitosa!',
                                    html: `
                                        <div style="padding: 10px;">
                                            <p style="font-size: 1.1rem; margin-bottom: 15px;">${response.message || 'Entidad creada exitosamente'}</p>
                                            <div style="background: rgba(40, 167, 69, 0.1); border-radius: 8px; padding: 12px; margin-top: 10px;">
                                                <i class="fas fa-university" style="color: #c5a367; margin-right: 8px;"></i>
                                                <strong style="color: #c5a367;">Entidad: ${nombre}</strong><br>
                                                <strong style="color: #c5a367;">Identificador: ${identificador}</strong>
                                            </div>
                                        </div>
                                    `,
                                    icon: 'success',
                                    confirmButtonText: '<i class="fas fa-arrow-right me-2"></i>Ir al Listado',
                                    confirmButtonColor: '#c5a367',
                                    background: '#1f060c',
                                    color: '#fff',
                                    customClass: { popup: 'custom-success-modal' },
                                    allowOutsideClick: false
                                }).then(() => {
                                    window.location.href = '/Entidades/Index';
                                });
                            } else {
                                $btn.html(textoOriginal).prop('disabled', false);
                                Swal.fire({
                                    title: 'Error',
                                    text: response.message || 'Error al crear la entidad',
                                    icon: 'error',
                                    confirmButtonColor: '#c5a367',
                                    background: '#1f060c',
                                    color: '#fff',
                                    customClass: { popup: 'custom-modal' }
                                });
                            }
                        } else {
                            // Si la respuesta no es JSON, probablemente es una redirección exitosa
                            Swal.fire({
                                title: '<i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i><br>¡Operación Exitosa!',
                                html: `
                                    <div style="padding: 10px;">
                                        <p style="font-size: 1.1rem; margin-bottom: 15px;">Entidad creada exitosamente</p>
                                        <div style="background: rgba(40, 167, 69, 0.1); border-radius: 8px; padding: 12px; margin-top: 10px;">
                                            <i class="fas fa-university" style="color: #c5a367; margin-right: 8px;"></i>
                                            <strong style="color: #c5a367;">Entidad: ${nombre}</strong><br>
                                            <strong style="color: #c5a367;">Identificador: ${identificador}</strong>
                                        </div>
                                    </div>
                                `,
                                icon: 'success',
                                confirmButtonText: '<i class="fas fa-arrow-right me-2"></i>Ir al Listado',
                                confirmButtonColor: '#c5a367',
                                background: '#1f060c',
                                color: '#fff',
                                customClass: { popup: 'custom-success-modal' },
                                allowOutsideClick: false
                            }).then(() => {
                                window.location.href = '/Entidades/Index';
                            });
                        }
                    },
                    error: function(xhr) {
                        isSubmitting = false;
                        $btn.html(textoOriginal).prop('disabled', false);
                        
                        let errorMsg = 'Error al crear la entidad';
                        
                        try {
                            const response = JSON.parse(xhr.responseText);
                            if (response.message) errorMsg = response.message;
                        } catch(e) {
                            if (xhr.status === 409) errorMsg = 'Ya existe una entidad con ese identificador';
                            else if (xhr.status === 500) errorMsg = 'Error interno del servidor';
                            else if (xhr.status === 200) {
                                // Si es 200 pero hay error en el parseo, probablemente fue exitoso
                                Swal.fire({
                                    title: '<i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i><br>¡Operación Exitosa!',
                                    html: `Entidad "${nombre}" creada exitosamente`,
                                    icon: 'success',
                                    confirmButtonText: 'Ir al Listado',
                                    confirmButtonColor: '#c5a367',
                                    background: '#1f060c',
                                    color: '#fff'
                                }).then(() => {
                                    window.location.href = '/Entidades/Index';
                                });
                                return;
                            }
                        }
                        
                        Swal.fire({
                            title: 'Error',
                            text: errorMsg,
                            icon: 'error',
                            confirmButtonColor: '#c5a367',
                            background: '#1f060c',
                            color: '#fff',
                            customClass: { popup: 'custom-modal' }
                        });
                    }
                });
            });
        });
    </script>
}
