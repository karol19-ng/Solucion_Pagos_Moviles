@model Pegasos.Web.Administrador.Models.EditarEntidadViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Editar Entidad";
}

@section Styles {
    <style>
        .form-container {
            background: rgba(31, 6, 12, 0.5);
            border: 1px solid var(--dorado-primario);
            border-radius: 8px;
            padding: 30px;
            backdrop-filter: blur(5px);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .form-header {
            background: linear-gradient(135deg, var(--vinotinto-sidebar) 0%, #4a0d1f 100%);
            border: 1px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 20px 25px;
            border-radius: 8px;
            margin-bottom: 30px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

            .form-header h4 {
                margin: 0;
                font-size: 1.5rem;
                font-weight: 600;
                text-shadow: 0 2px 4px rgba(0,0,0,0.3);
            }

            .form-header i {
                margin-right: 10px;
                color: var(--dorado-primario);
                font-size: 1.8rem;
            }

            .form-header .estado-badge {
                display: inline-block;
                padding: 5px 15px;
                border-radius: 4px;
                font-size: 0.85rem;
                font-weight: 600;
                margin-left: 15px;
            }

        .estado-activo {
            background: rgba(40, 167, 69, 0.2);
            color: #28a745;
            border: 1px solid #28a745;
        }

        .estado-inactivo {
            background: rgba(220, 53, 69, 0.2);
            color: #dc3545;
            border: 1px solid #dc3545;
        }

        .info-box {
            background: rgba(197, 163, 103, 0.1);
            border-left: 4px solid var(--dorado-primario);
            padding: 15px;
            margin-bottom: 25px;
            border-radius: 4px;
        }

            .info-box i {
                color: var(--dorado-primario);
                margin-right: 10px;
                font-size: 1.2rem;
            }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            color: var(--dorado-primario);
            font-weight: 600;
            margin-bottom: 8px;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

            .form-label i {
                margin-right: 8px;
                color: var(--dorado-primario);
            }

        .form-control-custom, .form-select-custom {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 15px;
            border-radius: 6px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

            .form-control-custom:focus, .form-select-custom:focus {
                background: rgba(255, 255, 255, 0.1);
                border-color: var(--dorado-primario);
                color: white;
                box-shadow: 0 0 0 3px rgba(197, 163, 103, 0.1);
                outline: none;
            }

            .form-control-custom::placeholder {
                color: rgba(255, 255, 255, 0.5);
                font-style: italic;
            }

        select.form-select-custom option {
            background: var(--vinotinto-sidebar);
            color: white;
        }

        .text-danger {
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
            color: #dc3545 !important;
        }

        .text-muted {
            color: rgba(255, 255, 255, 0.5) !important;
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
        }

        .btn-container {
            display: flex;
            justify-content: space-between;
            margin-top: 35px;
            padding-top: 20px;
            border-top: 2px solid rgba(197, 163, 103, 0.2);
        }

        .btn-secondary-custom {
            background: transparent;
            border: 1px solid rgba(197, 163, 103, 0.3);
            color: white;
            padding: 12px 30px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
        }

            .btn-secondary-custom:hover {
                background: rgba(255, 255, 255, 0.1);
                border-color: var(--dorado-primario);
                color: white;
                transform: translateY(-2px);
            }

        .btn-warning-custom {
            background: transparent;
            border: 2px solid var(--dorado-primario);
            color: var(--dorado-primario);
            padding: 12px 35px;
            border-radius: 6px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

            .btn-warning-custom:hover {
                background: var(--dorado-primario);
                color: var(--vinotinto-sidebar);
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(197, 163, 103, 0.3);
            }

            .btn-warning-custom i, .btn-secondary-custom i {
                margin-right: 8px;
            }

        .validation-summary-errors {
            background: rgba(220, 53, 69, 0.1);
            border: 1px solid #dc3545;
            color: #dc3545;
            padding: 15px 20px;
            border-radius: 6px;
            margin-bottom: 25px;
        }

        .required-field::after {
            content: "*";
            color: #dc3545;
            margin-left: 4px;
            font-weight: bold;
        }

        /* Estilos para SweetAlert2 - Modal de éxito personalizado */
        .custom-success-modal .swal2-popup {
            background: linear-gradient(135deg, #1f060c 0%, #2a0a14 100%);
            border: 2px solid var(--dorado-primario);
            border-radius: 15px;
            color: white;
        }

        .custom-success-modal .swal2-title {
            color: var(--dorado-primario);
            font-size: 1.8rem;
        }

        .custom-success-modal .swal2-html-container {
            color: #ffffff;
            font-size: 1.1rem;
        }

        .custom-success-modal .swal2-confirm {
            background: transparent !important;
            border: 2px solid var(--dorado-primario) !important;
            color: var(--dorado-primario) !important;
            border-radius: 8px !important;
            padding: 10px 30px !important;
            font-weight: 600 !important;
            transition: all 0.3s ease !important;
        }

            .custom-success-modal .swal2-confirm:hover {
                background: var(--dorado-primario) !important;
                color: #1f060c !important;
                transform: translateY(-2px);
            }

        .custom-success-modal .swal2-success-circular-line-left,
        .custom-success-modal .swal2-success-circular-line-right,
        .custom-success-modal .swal2-success-fix,
        .custom-success-modal .swal2-success-ring {
            background: transparent !important;
        }

        .custom-success-modal .swal2-success-line-tip,
        .custom-success-modal .swal2-success-line-long {
            background-color: var(--success-green) !important;
        }

        .custom-success-modal .swal2-icon.swal2-success {
            border-color: var(--success-green) !important;
        }

        /* Estilos para modal de error */
        .custom-modal .swal2-popup {
            background: linear-gradient(135deg, #1f060c 0%, #2a0a14 100%);
            border: 2px solid var(--dorado-primario);
            border-radius: 15px;
            color: white;
        }

        .custom-modal .swal2-title {
            color: var(--dorado-primario);
        }

        .custom-modal .swal2-html-container {
            color: #ffffff;
        }

        .custom-modal .swal2-confirm {
            background: transparent !important;
            border: 2px solid var(--dorado-primario) !important;
            color: var(--dorado-primario) !important;
            border-radius: 8px !important;
            padding: 10px 30px !important;
            font-weight: 600 !important;
            transition: all 0.3s ease !important;
        }

            .custom-modal .swal2-confirm:hover {
                background: var(--dorado-primario) !important;
                color: #1f060c !important;
                transform: translateY(-2px);
            }

        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
            z-index: 10000;
            display: none;
            justify-content: center;
            align-items: center;
            backdrop-filter: blur(5px);
        }

        .spinner-custom {
            width: 50px;
            height: 50px;
            border: 4px solid var(--dorado-primario);
            border-top-color: transparent;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-container">
                <div class="form-header">
                    <h4>
                        <i class="fas fa-edit me-2"></i>
                        Editar Entidad: @Model.Identificador
                        @if (Model.EstadoId == 1)
                        {
                            <span class="estado-badge estado-activo">ACTIVO</span>
                        }
                        else
                        {
                            <span class="estado-badge estado-inactivo">INACTIVO</span>
                        }
                    </h4>
                </div>

                <div class="info-box">
                    <i class="fas fa-info-circle"></i>
                    <strong>Modo Edición:</strong> Está modificando los datos de la entidad.
                </div>

                <form asp-action="Edit" method="post" id="editForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="Identificador" class="form-label">
                            <i class="fas fa-hashtag"></i> Identificador <span class="required-field"></span>
                        </label>
                        <input asp-for="Identificador" class="form-control form-control-custom"
                               id="Identificador" name="Identificador"
                               placeholder="Ej: BCR, BN, BAC" />
                        <span asp-validation-for="Identificador" class="text-danger" id="identificadorError"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Nombre" class="form-label">
                            <i class="fas fa-building"></i> Nombre <span class="required-field"></span>
                        </label>
                        <input asp-for="Nombre" class="form-control form-control-custom"
                               id="Nombre" name="Nombre"
                               placeholder="Ej: Banco de Costa Rica" />
                        <span asp-validation-for="Nombre" class="text-danger" id="nombreError"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="EstadoId" class="form-label">
                            <i class="fas fa-toggle-on"></i> Estado
                        </label>
                        <select asp-for="EstadoId" class="form-select form-select-custom">
                            <option value="1">Activo</option>
                            <option value="0">Inactivo</option>
                        </select>
                    </div>

                    <div class="btn-container">
                        <a asp-action="Index" class="btn-secondary-custom">
                            <i class="fas fa-arrow-left"></i> Regresar al Listado
                        </a>
                        <button type="submit" class="btn-warning-custom" id="btnActualizar">
                            <i class="fas fa-save"></i> Actualizar Entidad
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Loading Overlay -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="spinner-custom"></div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function showLoading() {
        $('#loadingOverlay').fadeIn(200);
        }

        function hideLoading() {
        $('#loadingOverlay').fadeOut(200);
        }

        $(document).ready(function() {
        // Validación en tiempo real
        $('#Identificador').on('input', function() {
        var valor = $(this).val();
        if (!valor || valor.trim() === '') {
        $('#identificadorError').text('El identificador es requerido');
        } else {
        $('#identificadorError').text('');
        }
        });

        $('#Nombre').on('input', function() {
        var valor = $(this).val();
        if (!valor || valor.trim() === '') {
        $('#nombreError').text('El nombre es requerido');
        } else {
        $('#nombreError').text('');
        }
        });

        // Validación al enviar con SweetAlert2
        $('#editForm').on('submit', function(e) {
        e.preventDefault();
                
        var identificador = $('#Identificador').val();
        var nombre = $('#Nombre').val();
        var estadoId = $('#EstadoId').val();
        var errores = [];

        if (!identificador || identificador.trim() === '') {
        errores.push('El identificador es requerido');
        }

        if (!nombre || nombre.trim() === '') {
        errores.push('El nombre es requerido');
        }

        if (errores.length > 0) {
        Swal.fire({
        title: 'Campos incompletos',
        html: '<div style="text-align: left;">Por favor complete todos los campos requeridos:<br>• ' + errores.join('<br>• ') + '</div>',
        icon: 'warning',
        confirmButtonColor: '#c5a367',
        background: '#1f060c',
        color: '#fff',
        customClass: {
        popup: 'custom-modal'
        }
        });
        return false;
        }

        // Deshabilitar botón y mostrar loading
        var $btn = $('#btnActualizar');
        var textoOriginal = $btn.html();
        $btn.html('<i class="fas fa-spinner fa-spin me-2"></i>Actualizando...').prop('disabled', true);
        showLoading();
                
        var form = $(this);
        var url = form.attr('action');
        var data = form.serialize();
                
        $.ajax({
        url: url,
        type: 'POST',
        data: data,
        dataType: 'text',
        success: function(response) {
        hideLoading();
        $btn.html(textoOriginal).prop('disabled', false);
                        
        console.log('Respuesta CRUDA del servidor:', response);
                        
        // Verificar si la respuesta contiene una redirección o HTML
        if (response.includes('<!DOCTYPE') || response.includes('<html') || response.includes('redirect')) {
        Swal.fire({
        title: '<i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i><br>¡Operación Exitosa!',
        html: `
        <div style="padding: 10px;">
        <p style="font-size: 1.1rem; margin-bottom: 15px;">Entidad "${nombre}" actualizada exitosamente</p>
        <div style="background: rgba(40, 167, 69, 0.1); border-radius: 8px; padding: 12px; margin-top: 10px;">
        <i class="fas fa-university" style="color: #c5a367; margin-right: 8px;"></i>
        <strong style="color: #c5a367;">Entidad: ${nombre}</strong>
        <br>
        <small style="color: #c5a367;">Estado: ${estadoId == 1 ? 'Activo' : 'Inactivo'}</small>
        </div>
        </div>
        `,
        icon: 'success',
        confirmButtonText: '<i class="fas fa-arrow-right me-2"></i>Ir al Listado',
        confirmButtonColor: '#c5a367',
        background: '#1f060c',
        color: '#fff',
        customClass: {
        popup: 'custom-success-modal'
        },
        allowOutsideClick: false
        }).then(() => {
        window.location.href = '/Entidades/Index';
        });
        return;
        }
                        
        // Intentar parsear como JSON
        try {
        var jsonResponse = JSON.parse(response);
        console.log('Respuesta JSON parseada:', jsonResponse);
                            
        if (jsonResponse.success === true || jsonResponse.codigo === 0) {
        Swal.fire({
        title: '<i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i><br>¡Operación Exitosa!',
        html: `
        <div style="padding: 10px;">
        <p style="font-size: 1.1rem; margin-bottom: 15px;">${jsonResponse.message || jsonResponse.descripcion || 'Entidad actualizada exitosamente'}</p>
        <div style="background: rgba(40, 167, 69, 0.1); border-radius: 8px; padding: 12px; margin-top: 10px;">
        <i class="fas fa-university" style="color: #c5a367; margin-right: 8px;"></i>
        <strong style="color: #c5a367;">Entidad: ${nombre}</strong>
        <br>
        <small style="color: #c5a367;">Estado: ${estadoId == 1 ? 'Activo' : 'Inactivo'}</small>
        </div>
        </div>
        `,
        icon: 'success',
        confirmButtonText: '<i class="fas fa-arrow-right me-2"></i>Ir al Listado',
        confirmButtonColor: '#c5a367',
        background: '#1f060c',
        color: '#fff',
        customClass: {
        popup: 'custom-success-modal'
        },
        allowOutsideClick: false
        }).then(() => {
        window.location.href = '/Entidades/Index';
        });
        } else {
        Swal.fire({
        title: 'Error',
        text: jsonResponse.message || jsonResponse.descripcion || 'Error al actualizar la entidad',
        icon: 'error',
        confirmButtonColor: '#c5a367',
        background: '#1f060c',
        color: '#fff',
        customClass: {
        popup: 'custom-modal'
        }
        });
        }
        } catch(e) {
        console.log('No es JSON, mostrando éxito por defecto');
        Swal.fire({
        title: '<i class="fas fa-check-circle" style="color: #28a745; font-size: 2rem;"></i><br>¡Operación Exitosa!',
        html: `
        <div style="padding: 10px;">
        <p style="font-size: 1.1rem; margin-bottom: 15px;">Entidad "${nombre}" actualizada exitosamente</p>
        <div style="background: rgba(40, 167, 69, 0.1); border-radius: 8px; padding: 12px; margin-top: 10px;">
        <i class="fas fa-university" style="color: #c5a367; margin-right: 8px;"></i>
        <strong style="color: #c5a367;">Entidad: ${nombre}</strong>
        <br>
        <small style="color: #c5a367;">Estado: ${estadoId == 1 ? 'Activo' : 'Inactivo'}</small>
        </div>
        </div>
        `,
        icon: 'success',
        confirmButtonText: '<i class="fas fa-arrow-right me-2"></i>Ir al Listado',
        confirmButtonColor: '#c5a367',
        background: '#1f060c',
        color: '#fff',
        customClass: {
        popup: 'custom-success-modal'
        },
        allowOutsideClick: false
        }).then(() => {
        window.location.href = '/Entidades/Index';
        });
        }
        },
        error: function(xhr) {
        hideLoading();
        $btn.html(textoOriginal).prop('disabled', false);
                        
        console.log('Error XHR:', xhr);
                        
        let errorMsg = 'Error al actualizar la entidad';
        try {
        const response = JSON.parse(xhr.responseText);
        if (response.message) errorMsg = response.message;
        } catch(e) {
        if (xhr.status === 409) {
        errorMsg = 'Ya existe una entidad con ese identificador';
        } else if (xhr.status === 500) {
        errorMsg = 'Error interno del servidor. Por favor, intente nuevamente.';
        } else if (xhr.responseText && xhr.responseText.length < 200) {
        errorMsg = xhr.responseText;
        }
        }
                        
        Swal.fire({
        title: 'Error de Operación',
        html: `
        <div style="padding: 10px;">
        <p>${errorMsg}</p>
        <div style="background: rgba(220, 53, 69, 0.1); border-radius: 8px; padding: 12px; margin-top: 10px;">
        <i class="fas fa-info-circle"></i>
        <small>Código: ${xhr.status} - Verifique los datos e intente nuevamente</small>
        </div>
        </div>
        `,
        icon: 'error',
        confirmButtonColor: '#c5a367',
        background: '#1f060c',
        color: '#fff',
        customClass: {
        popup: 'custom-modal'
        }
        });
        }
        });
        });

        // Confirmar cambios antes de salir
        var formModified = false;
        $('input, select').on('change', function() { formModified = true; });
        $('input').on('keyup', function() { formModified = true; });

        $('a[asp-action="Index"]').click(function(e) {
        if (formModified) {
        e.preventDefault();
        Swal.fire({
        title: '¿Salir sin guardar?',
        text: 'Tiene cambios sin guardar. ¿Está seguro que desea salir?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#c5a367',
        cancelButtonColor: '#dc3545',
        confirmButtonText: '<i class="fas fa-sign-out-alt me-2"></i>Sí, salir',
        cancelButtonText: '<i class="fas fa-times me-2"></i>Cancelar',
        background: '#1f060c',
        color: '#fff',
        customClass: {
        popup: 'custom-modal'
        }
        }).then((result) => {
        if (result.isConfirmed) {
        window.location.href = $(this).attr('href');
        }
        });
        }
        });
        });
    </script>
}