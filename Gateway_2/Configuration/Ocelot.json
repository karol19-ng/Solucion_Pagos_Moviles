{
  "Routes": [
    // 1. LOGIN (PÚBLICO - Prioridad Alta)
    {
      "DownstreamPathTemplate": "/auth/login",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7258
        }
      ],
      "UpstreamPathTemplate": "/auth/login",
      "UpstreamHttpMethod": [ "POST" ],
      "Priority": 2
    },

    // 2. REFRESH Y VALIDATE (PÚBLICOS)
    {
      "DownstreamPathTemplate": "/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5005
        }
      ],
      "UpstreamPathTemplate": "/auth/{everything}",
      "UpstreamHttpMethod": [ "POST" ],
      "Priority": 1
    },

    // 3. BITACORA (REQUERIR TOKEN)
    {
      "DownstreamPathTemplate": "/api/bitacora/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5004
        }
      ],
      "UpstreamPathTemplate": "/bitacora/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "GatewayAuth"
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5200"
  }
}