{
  "Routes": [
    // 1. LOGIN (PÚBLICO)
    {
      "DownstreamPathTemplate": "/auth/login",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7258
        }
      ],
      "UpstreamPathTemplate": "/auth/login",
      "UpstreamHttpMethod": [ "POST" ]
    },

    // 2. REGISTER (REQUIERE TOKEN - Usando GatewayAuth)
    {
      "DownstreamPathTemplate": "/auth/register",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7258
        }
      ],
      "UpstreamPathTemplate": "/auth/register",
      "UpstreamHttpMethod": [ "POST" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "GatewayAuth"
      }
    },

    // 3. CANCEL-SUBSCRIPTION (REQUIERE TOKEN)
    {
      "DownstreamPathTemplate": "/auth/cancel-subscription",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7258
        }
      ],
      "UpstreamPathTemplate": "/auth/cancel-subscription",
      "UpstreamHttpMethod": [ "POST" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "GatewayAuth"
      }
    },

    // 4. REFRESH (PÚBLICO)
    {
      "DownstreamPathTemplate": "/auth/refresh",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7258
        }
      ],
      "UpstreamPathTemplate": "/auth/refresh",
      "UpstreamHttpMethod": [ "POST" ]
    },

    // 5. VALIDATE (PÚBLICO)
    {
      "DownstreamPathTemplate": "/auth/validate",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7258
        }
      ],
      "UpstreamPathTemplate": "/auth/validate",
      "UpstreamHttpMethod": [ "POST" ]
    },

    // 6. BITACORA (REQUIERE TOKEN)
    {
      "DownstreamPathTemplate": "/api/bitacora/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5004
        }
      ],
      "UpstreamPathTemplate": "/bitacora/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "GatewayAuth"
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5200"
  }
}