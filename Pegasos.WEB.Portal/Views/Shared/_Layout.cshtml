﻿
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pegasos Bank Clientes</title>

    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- Sidebar solo visible para usuarios autenticados -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <img src="/images/logo_pegasos.png" class="sidebar-logo" alt="Pegasos Logo">
                <div class="sidebar-title">PEGASOS BANK</div>
                <div class="sidebar-subtitle">Portal Cliente</div>
            </div>

            <nav class="sidebar-menu">
                <p class="menu-section-title">Principal</p>
                <a href="@Url.Action("Index", "Home")" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <i class="fas fa-home"></i> Inicio
                </a>

                <p class="menu-section-title" style="margin-top: 20px;">Pagos Móviles</p>
                <a href="@Url.Action("Index", "Inscripcion")" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inscripcion" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fas fa-mobile-alt"></i> Inscribirse
                </a>
                <a href="@Url.Action("Desinscribir", "Inscripcion")" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inscripcion" && ViewContext.RouteData.Values["action"]?.ToString() == "Desinscribir" ? "active" : "")">
                    <i class="fas fa-ban"></i> Desinscribirse
                </a>

                <p class="menu-section-title" style="margin-top: 20px;">Operaciones</p>
                <a href="@Url.Action("Index", "Transferencias")" class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Transferencias" ? "active" : "")">
                    <i class="fas fa-exchange-alt"></i> Transferir
                </a>
                <a href="@Url.Action("Saldo", "Consultas")" class="menu-item">
                    <i class="fas fa-wallet"></i> Consultar Saldo
                </a>
                <a href="@Url.Action("Movimientos", "Consultas")" class="menu-item">
                    <i class="fas fa-history"></i> Últimos Movimientos
                </a>

                <p class="menu-section-title" style="margin-top: 20px;">Seguridad</p>
                <a href="@Url.Action("Logout", "Auth")" class="menu-item text-danger">
                    <i class="fas fa-sign-out-alt"></i> Cerrar Sesión
                </a>
            </nav>
        </aside>

        <div class="main-wrapper">
            <header class="top-user-bar">
                <span>
                    <i class="fas fa-user-circle me-2" style="color: var(--dorado-primario)"></i>
                    Cliente: <strong>@User.FindFirst("nombreCompleto")?.Value</strong>
                </span>
                <span class="ms-3" id="sessionTimer" style="font-size: 0.8rem; color: var(--dorado-primario);">
                    <i class="fas fa-clock"></i> 05:00
                </span>
            </header>

            <main role="main" class="main-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="crud-container">
                    @RenderBody()
                </div>
            </main>

            <footer class="text-muted">
                <div class="container-fluid">
                    &copy; 2026 - Pegasos Bank - Portal Cliente v2.0
                </div>
            </footer>
        </div>
    }
    else
    {
        <!-- Sin sidebar para login -->
        @RenderBody()
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/portal-custom.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="~/js/session-timeout.js"></script>
        <script>
                // Iniciar contador de sesión (5 minutos)
                iniciarContadorSesion(5, '@Url.Action("Logout", "Auth")');
        </script>
    }
</body>
</html>