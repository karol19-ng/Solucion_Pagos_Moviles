@model TransferenciaViewModel
@{
    ViewData["Title"] = "Transferencia Confirmada";
}

<div class="text-center py-4">
    <div class="success-icon mb-4">
        <i class="fas fa-check-circle fa-5x" style="color: #10b981;"></i>
    </div>

    <h2 class="text-success mb-4">¡Transferencia Exitosa!</h2>

    <div class="comprobante-card mx-auto" style="max-width: 500px;">
        <h5 class="mb-3" style="color: var(--dorado-primario);">
            <i class="fas fa-receipt"></i> Comprobante de Transferencia
        </h5>

        <table class="table table-dark table-borderless text-start">
            <tr>
                <td class="text-muted">Fecha:</td>
                <td class="text-end"><strong>@Model.Fecha.ToString("dd/MM/yyyy HH:mm")</strong></td>
            </tr>
            <tr>
                <td class="text-muted">Comprobante:</td>
                <td class="text-end"><strong>@Model.Comprobante</strong></td>
            </tr>
            <tr>
                <td class="text-muted">Teléfono Origen:</td>
                <td class="text-end"><strong>@Model.TelefonoOrigen</strong></td>
            </tr>
            <tr>
                <td class="text-muted">Nombre Origen:</td>
                <td class="text-end"><strong>@Model.NombreOrigen</strong></td>
            </tr>
            <tr>
                <td class="text-muted">Teléfono Destino:</td>
                <td class="text-end"><strong>@Model.TelefonoDestino</strong></td>
            </tr>
            <tr>
                <td class="text-muted">Monto:</td>
                <td class="text-end"><strong style="color: var(--dorado-primario);">@Model.Monto.ToString("C2")</strong></td>
            </tr>
            <tr>
                <td class="text-muted">Descripción:</td>
                <td class="text-end"><strong>@Model.Descripcion</strong></td>
            </tr>
        </table>

        <div class="mt-4">
            <button onclick="window.print()" class="btn btn-secondary me-2">
                <i class="fas fa-print"></i> Imprimir
            </button>
            <a href="@Url.Action("Index", "Transferencias")" class="btn btn-pegasos">
                <i class="fas fa-exchange-alt"></i> Nueva Transferencia
            </a>
        </div>
    </div>
</div>

<style>
    .comprobante-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(197, 163, 103, 0.2);
        border-radius: 12px;
        padding: 30px;
        margin-top: 20px;
    }

    .table-dark {
        --bs-table-bg: transparent;
        --bs-table-border-color: rgba(197, 163, 103, 0.1);
    }

    .table-dark td {
        border-color: rgba(197, 163, 103, 0.1);
    }

    @@media print {
        body {
            background: white;
            color: black;
        }
        .comprobante-card {
            background: white;
            color: black;
            border: 1px solid #ccc;
        }
        .table-dark {
            color: black;
        }
        .btn {
            display: none;
        }
    }
</style>