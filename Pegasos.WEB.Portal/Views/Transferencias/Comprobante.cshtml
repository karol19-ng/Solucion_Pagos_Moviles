@{
    ViewData["Title"] = "Comprobante";
    var comprobanteId = ViewBag.ComprobanteId as string;
}

<div class="text-center py-5">
    <i class="fas fa-file-invoice fa-4x mb-3" style="color: var(--dorado-primario);"></i>
    <h3>Comprobante @comprobanteId</h3>
    <p class="text-muted">Detalle del comprobante de transferencia</p>
    
    <div class="mt-4">
        <a href="@Url.Action("Index", "Transferencias")" class="btn btn-pegasos">
            <i class="fas fa-exchange-alt"></i> Nueva Transferencia
        </a>
    </div>
</div>