@model TransferirInput
@{
    ViewData["Title"] = "Realizar Transferencia";
}

<div class="header-section">
    <h2 class="page-title">
        <i class="fas fa-exchange-alt me-2"></i> Realizar Transferencia
    </h2>
    <p class="text-muted">Complete los datos de la transferencia</p>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="info-box mb-4">
            <i class="fas fa-info-circle"></i>
            <span>Monto máximo permitido: ₡100,000.00 por transacción</span>
        </div>

        <form asp-action="RealizarTransferencia" asp-controller="Transferencias" method="POST" class="mt-4">
            @Html.AntiForgeryToken()

            <div class="form-group mb-3">
                <label class="form-label">Nombre Origen</label>
                <input value="@Model.NombreOrigen" class="form-control" readonly disabled />
                <span class="text-muted small">Su nombre registrado</span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TelefonoOrigen" class="form-label">Teléfono Origen</label>
                <input asp-for="TelefonoOrigen" class="form-control" placeholder="8888-5555" required />
                <span asp-validation-for="TelefonoOrigen" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TelefonoDestino" class="form-label">Teléfono Destino</label>
                <input asp-for="TelefonoDestino" class="form-control" placeholder="8888-6666" required />
                <span asp-validation-for="TelefonoDestino" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Monto" class="form-label">Monto</label>
                <div class="input-group">
                    <span class="input-group-text" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(197,163,103,0.3); color: var(--dorado-primario);">₡</span>
                    <input asp-for="Monto" class="form-control" type="number" step="0.01" min="1" max="100000" required />
                </div>
                <span asp-validation-for="Monto" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Descripcion" class="form-label">Descripción</label>
                <textarea asp-for="Descripcion" class="form-control" rows="2" maxlength="25" placeholder="Motivo de la transferencia"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
                <span class="text-muted small">Máximo 25 caracteres</span>
            </div>

            <div class="form-group text-center">
                <button type="submit" class="btn btn-pegasos px-5">
                    <i class="fas fa-paper-plane me-2"></i> Realizar Transferencia
                </button>
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary ms-2">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .info-box {
        background: rgba(197, 163, 103, 0.1);
        border: 1px solid rgba(197, 163, 103, 0.3);
        border-radius: 8px;
        padding: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--dorado-primario);
    }

    .input-group-text {
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(197,163,103,0.3);
        color: var(--dorado-primario);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}