@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acceso Denegado - Pegasos Bank</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
            :root {
                --vinotinto-oscuro: #2b0811;
                --vinotinto-medio: #4a0e1e;
                --dorado-primario: #c5a367;
            }

            body {
                background: radial-gradient(circle, var(--vinotinto-medio) 0%, var(--vinotinto-oscuro) 100%);
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Montserrat', sans-serif;
                margin: 0;
            }

            .access-denied-card {
                background: rgba(255, 255, 255, 0.03);
                backdrop-filter: blur(15px);
                border: 1px solid rgba(197, 163, 103, 0.2);
                padding: 3rem;
                border-radius: 15px;
                max-width: 500px;
                text-align: center;
                color: white;
            }

            .icon {
                font-size: 5rem;
                color: #ff6b6b;
                margin-bottom: 1rem;
            }

            h1 {
                font-family: 'Cinzel', serif;
                color: var(--dorado-primario);
                margin-bottom: 1rem;
            }

            p {
                margin-bottom: 2rem;
                opacity: 0.8;
            }

            .btn {
                background: linear-gradient(135deg, #c5a367 0%, #8e6d31 100%);
                border: none;
                padding: 12px 30px;
                border-radius: 5px;
                color: #1a050a;
                text-decoration: none;
                font-weight: 600;
                letter-spacing: 1px;
                transition: all 0.3s;
            }

                .btn:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
                }
    </style>
</head>
<body>
    <div class="access-denied-card">
        <div class="icon">⚠️</div>
        <h1>Acceso Denegado</h1>
        <p>No tiene permisos para acceder a esta página.<br>Esta área es exclusiva para clientes del banco.</p>
        <a href="@Url.Action("Login", "Auth")" class="btn">Ir al Login</a>
    </div>
</body>
</html>