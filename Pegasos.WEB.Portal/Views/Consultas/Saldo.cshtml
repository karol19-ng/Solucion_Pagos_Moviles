@model SaldoViewModel
@{
    ViewData["Title"] = "Consultar Saldo";
}

<div class="header-section">
    <h2 class="page-title">
        <i class="fas fa-wallet me-2"></i> Consultar Saldo
    </h2>
    <p class="text-muted">Ingrese su número de teléfono para consultar el saldo</p>
</div>

<div class="row">
    <div class="col-md-6 mx-auto">
        <div class="info-box mb-4">
            <i class="fas fa-info-circle"></i>
            <span>Ingrese el número de teléfono asociado a su cuenta de pagos móviles</span>
        </div>

        <form asp-action="ConsultarSaldo" asp-controller="Consultas" method="POST" class="mt-4">
            @Html.AntiForgeryToken()

            <div class="form-group mb-4">
                <label asp-for="Telefono" class="form-label">Número de Teléfono</label>
                <div class="input-group">
                    <span class="input-group-text" style="background: rgba(0,0,0,0.3); border: 1px solid rgba(197,163,103,0.3); color: var(--dorado-primario);">
                        <i class="fas fa-phone"></i>
                    </span>
                    <input asp-for="Telefono" class="form-control" placeholder="70407040"
                           onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                           maxlength="8" />
                </div>
                <span asp-validation-for="Telefono" class="text-danger"></span>
                <small class="text-muted">8 dígitos, sin espacios ni guiones</small>
            </div>

            <div class="form-group text-center">
                <button type="submit" class="btn btn-pegasos px-5">
                    <i class="fas fa-search me-2"></i> Consultar Saldo
                </button>
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary ms-2">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .info-box {
        background: rgba(197, 163, 103, 0.1);
        border: 1px solid rgba(197, 163, 103, 0.3);
        border-radius: 8px;
        padding: 15px;
        display: flex;
        align-items: center;
        gap: 10px;
        color: var(--dorado-primario);
    }

    .input-group-text {
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(197,163,103,0.3);
        color: var(--dorado-primario);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('Telefono').addEventListener('input', function (e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });
    </script>
}