@model SaldoViewModel
@{
    ViewData["Title"] = "Consultar Saldo";
    var esCliente = User.IsInRole("Cliente");
    var esAdmin = User.IsInRole("Administrador");
}

<div class="header-section">
    <h2 class="page-title">
        <i class="fas fa-wallet me-2"></i> Consultar Saldo
    </h2>
    <p class="text-muted">Complete los datos para consultar el saldo de una cuenta</p>
</div>

<div class="row">
    <div class="col-md-6 mx-auto">
        <form asp-action="ConsultarSaldo" asp-controller="Consultas" method="POST" class="mt-4">
            @Html.AntiForgeryToken()

            <div class="form-group mb-3">
                <label asp-for="Identificacion" class="form-label">Identificación</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fas fa-id-card"></i>
                    </span>
                    <input asp-for="Identificacion" class="form-control" placeholder="Ej: 108880111" required />
                </div>
                <span asp-validation-for="Identificacion" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Telefono" class="form-label">Número de Teléfono</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fas fa-phone"></i>
                    </span>
                    <input asp-for="Telefono" class="form-control" placeholder="88881111" required
                           onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                           maxlength="8" />
                </div>
                <span asp-validation-for="Telefono" class="text-danger"></span>
                <small class="text-muted">8 dígitos, solo números</small>
            </div>

            <div class="form-group text-center">
                <button type="submit" class="btn btn-pegasos px-5">
                    <i class="fas fa-search me-2"></i> Consultar Saldo
                </button>
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary ms-2">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .input-group-text {
        background: rgba(0,0,0,0.3);
        border: 1px solid rgba(197,163,103,0.3);
        color: var(--dorado-primario);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('Telefono').addEventListener('input', function (e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });
    </script>
}