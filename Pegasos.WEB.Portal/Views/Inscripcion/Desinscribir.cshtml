@model InscripcionViewModel
@{
    ViewData["Title"] = "Desinscripción de Pagos Móviles";
}

<div class="header-section">
    <h2 class="page-title">
        <i class="fas fa-ban me-2"></i> Desinscripción de Pagos Móviles
    </h2>
    <p class="text-muted">Complete el formulario para desasociar su cuenta de pagos móviles</p>
</div>

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="alert alert-warning mb-4">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Importante:</strong> Al desinscribirse, no podrá recibir ni realizar transferencias mediante pagos móviles hasta que se inscriba nuevamente.
        </div>

        <form asp-action="Desinscribir" asp-controller="Inscripcion" method="POST" class="mt-4">
            @Html.AntiForgeryToken()

            <div class="form-group mb-3">
                <label asp-for="Identificacion" class="form-label">Identificación</label>
                <input asp-for="Identificacion" class="form-control" placeholder="Ingrese su número de identificación" required />
                <span asp-validation-for="Identificacion" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NumeroCuenta" class="form-label">Número de Cuenta</label>
                <input asp-for="NumeroCuenta" class="form-control" placeholder="Ej: CR123456789" required />
                <span asp-validation-for="NumeroCuenta" class="text-danger"></span>
            </div>

            <div class="form-group mb-4">
                <label asp-for="Telefono" class="form-label">Número de Teléfono</label>
                <input asp-for="Telefono" class="form-control" placeholder="8888-5555" required />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>

            <div class="form-group text-center">
                <button type="submit" class="btn btn-danger px-5">
                    <i class="fas fa-ban me-2"></i> Confirmar Desinscripción
                </button>
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary ms-2">
                    Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}