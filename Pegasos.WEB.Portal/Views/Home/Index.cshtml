@model BienvenidaViewModel
@{
    ViewData["Title"] = "Bienvenido";
}

<div class="welcome-container">
    <div class="welcome-card">
        <div class="text-center">
            <img src="/images/logo_pegasos.png" alt="Logo Banco Pegasos" class="welcome-logo mb-4">
            
            <h1 class="display-5 mb-3" style="color: var(--dorado-primario); font-family: 'Cinzel', serif;">
                ¡Bienvenido!
            </h1>
            
            <h2 class="mb-4" style="color: white;">
                @Model.NombreCompleto
            </h2>
            
            <p class="text-muted mb-0">
                <i class="fas fa-clock me-2"></i>
                @Model.FechaIngreso.ToString("dd 'de' MMMM 'de' yyyy") - @Model.HoraIngreso
            </p>
        </div>
    </div>
</div>

<style>
    .welcome-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .welcome-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(197, 163, 103, 0.2);
        border-radius: 20px;
        padding: 3rem;
        max-width: 500px;
        width: 100%;
        text-align: center;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
    }

    .welcome-logo {
        width: 120px;
        filter: drop-shadow(0 0 10px var(--dorado-primario));
    }
</style>